<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
  <%- include('partials/head') %>
  <title>تقييمات عملائنا — <%= product.title %></title>
</head>
<body>
  <div class="pattern-overlay"></div>

  <!-- Navbar -->
  <nav class="navbar scrolled">
    <div class="container">
      <div class="navbar__inner">
        <div class="navbar__brand">
          <a href="/" style="display: flex; align-items: center; gap: 10px;">
            <div class="navbar__logo"><%= typeof siteName !== 'undefined' ? siteName.charAt(0) : 'م' %></div>
            <span class="navbar__name"><%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></span>
          </a>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
          <a href="/product/<%= product.slug %>/checkout" class="navbar__cta">🛒 اطلب الآن</a>
          <% if (typeof sidebarCategories !== 'undefined' && sidebarCategories && sidebarCategories.length > 0) { %>
          <button type="button" onclick="openSidebar()" style="background: none; border: none; font-size: 22px; cursor: pointer; color: var(--color-text); padding: 4px; line-height: 1; opacity: 0.8;" title="القائمة">☰</button>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Reviews Hero -->
  <section class="reviews-hero">
    <div class="container">
      <div class="reviews-hero__inner">
        <h1 class="reviews-hero__title">تقييمات عملائنا</h1>
        <div class="reviews-hero__rating">
          <span class="reviews-hero__stars">
            <% for (let i = 1; i <= 5; i++) { %>
              <% if (i <= Math.round(parseFloat(avgRating))) { %>★<% } else { %>☆<% } %>
            <% } %>
          </span>
          <span class="reviews-hero__score"><%= avgRating %></span>
          <span class="reviews-hero__count"><%= reviewCount %> تقييم</span>
        </div>
        <button type="button" class="btn btn--primary" id="heroWriteReviewBtn" onclick="toggleReviewForm(true)">اكتب تقييمك</button>
      </div>
    </div>
  </section>

  <!-- Reviews List -->
  <section class="reviews-list" id="reviewsList">
    <div class="container container--narrow">
      <% if (reviews.length === 0) { %>
        <div style="text-align: center; padding: 40px 20px; color: var(--color-text-muted);">
          <p style="font-size: 48px; margin-bottom: 16px;">💬</p>
          <p style="font-size: 18px; font-weight: 600; margin-bottom: 8px;">لا توجد تقييمات بعد</p>
          <p style="font-size: 14px;">كن أول من يشارك تجربته!</p>
        </div>
      <% } else { %>
        <% reviews.forEach(function(review) { %>
          <div class="review-card animate-on-scroll">
            <div class="review-card__header">
              <div class="review-card__avatar" style="font-size: 24px; display: flex; align-items: center; justify-content: center;"><%= (function(n){ var e=['😊','😎','🤩','😇','🥰','😄','🤗','😺','🦊','🐻','🐶','🐱','🐸','🦁','🐼','🐯','🐨','🦋','🌸','⭐']; var h=0; for(var i=0;i<n.length;i++) h=((h<<5)-h)+n.charCodeAt(i); return e[Math.abs(h)%e.length]; })(review.name) %></div>
              <div>
                <div class="review-card__name" style="display: flex; align-items: center; gap: 6px;"><%= review.name %> <span style="background: var(--color-success, #2D8F5E); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 4px; white-space: nowrap;">✓ موثّق</span></div>
                <div class="review-card__stars">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <% if (i <= review.rating) { %>★<% } else { %>☆<% } %>
                  <% } %>
                </div>
              </div>
            </div>
            <div class="review-card__text"><%= review.message %></div>

            <% if (review.image_filename) { %>
              <div style="margin-top: 16px; text-align: center;">
                <img src="/uploads/reviews/<%= review.image_filename %>" alt="صورة التقييم" style="max-width: 100%; max-height: 300px; border-radius: var(--radius-md); object-fit: cover; border: 1px solid var(--color-border-light);" loading="lazy">
              </div>
            <% } %>

            <% if (review.audio_filename) { %>
              <div class="wa-audio-player" data-src="/uploads/reviews/<%= review.audio_filename %>" style="margin-top: 16px;">
                <button type="button" class="wa-play-btn" onclick="toggleWaAudio(this)">▶</button>
                <div class="wa-progress-wrap" onclick="seekWaAudio(event, this)">
                  <div class="wa-waveform"></div>
                </div>
                <span class="wa-time">0:00</span>
              </div>
            <% } %>
          </div>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- Write Review Section -->
  <section class="write-review" id="writeReview" style="display: none;">
    <div class="container container--narrow">
      <div style="text-align: center; margin-bottom: 24px;">
        <button type="button" class="btn btn--outline" onclick="toggleReviewForm(false)">العودة للتقييمات</button>
      </div>
      <div class="section-header">
        <span class="section-header__label">شاركنا رأيك</span>
        <h2 class="section-header__title">اكتب تقييمك</h2>
        <div class="section-header__divider"></div>
      </div>

      <div class="feedback-card">
        <form id="reviewForm" novalidate>

          <div class="feedback-form__row">
            <div class="form-group">
              <label class="form-label" for="reviewName">
                <span class="required">*</span>
                الاسم
              </label>
              <input type="text" id="reviewName" name="name" class="form-input" placeholder="أدخل اسمك" required>
              <div class="form-error"></div>
            </div>

            <div class="form-group">
              <label class="form-label" for="reviewPhone">
                <span class="required">*</span>
                رقم الهاتف
              </label>
              <div class="form-input-phone-wrapper">
                <div class="form-input-phone-prefix">+212</div>
                <input type="tel" id="reviewPhone" name="phone" class="form-input" placeholder="6XXXXXXXX" required dir="ltr">
              </div>
              <div class="form-error"></div>
            </div>
          </div>

          <!-- Star Rating -->
          <div class="form-group">
            <label class="form-label">التقييم</label>
            <div class="feedback-stars" id="reviewStars">
              <span class="feedback-star" data-rating="1">☆</span>
              <span class="feedback-star" data-rating="2">☆</span>
              <span class="feedback-star" data-rating="3">☆</span>
              <span class="feedback-star" data-rating="4">☆</span>
              <span class="feedback-star" data-rating="5">☆</span>
            </div>
            <input type="hidden" id="reviewRating" name="rating" value="5">
          </div>

          <!-- Message -->
          <div class="form-group">
            <label class="form-label" for="reviewMessage">
              <span class="required">*</span>
              تقييمك
            </label>
            <textarea id="reviewMessage" name="message" class="form-input form-textarea" placeholder="شاركنا تجربتك مع المنتج..." rows="4" required></textarea>
            <div class="form-error"></div>
          </div>

          <!-- Image Upload -->
          <div class="form-group">
            <label class="form-label">صورة (اختياري)</label>
            <div class="feedback-upload-zone">
              <div class="feedback-upload-zone__icon">📷</div>
              <div class="feedback-upload-zone__text">اضغط لإضافة صورة</div>
              <div class="feedback-upload-zone__hint">JPG, PNG — الحد الأقصى 5MB</div>
              <input type="file" id="reviewImage" name="image" accept="image/*">
            </div>
            <div class="feedback-upload-preview">
              <img class="feedback-upload-preview__img" src="" alt="معاينة">
              <div class="feedback-upload-preview__name"></div>
              <button type="button" class="feedback-upload-preview__remove">✕</button>
            </div>
          </div>

          <!-- Voice Recorder -->
          <div class="form-group">
            <label class="form-label">تسجيل صوتي (اختياري)</label>
            <div class="voice-recorder" id="reviewVoiceRecorder">
              <button type="button" class="voice-recorder__btn" id="reviewVoiceRecordBtn">
                <span class="voice-recorder__icon">🎙️</span>
                <span class="voice-recorder__label">اضغط للتسجيل</span>
              </button>
              <div class="voice-recorder__status" id="reviewVoiceStatus"></div>
              <div class="voice-recorder__player" id="reviewVoicePlayer">
                <audio id="reviewVoiceAudio" controls></audio>
                <button type="button" class="voice-recorder__remove" id="reviewVoiceRemoveBtn">حذف</button>
              </div>
            </div>
          </div>

          <button type="submit" class="btn btn--primary btn--lg btn--full">إرسال التقييم</button>

          <p class="feedback-form__note">سيتم مراجعة تقييمك قبل النشر</p>
        </form>

        <!-- Success State -->
        <div class="feedback-success" id="reviewSuccess">
          <div class="feedback-success__icon">🎉</div>
          <h3 class="feedback-success__title">شكراً لك!</h3>
          <p class="feedback-success__text">تم إرسال تقييمك بنجاح. سيتم نشره بعد المراجعة.</p>
          <a href="/product/<%= product.slug %>" class="btn btn--primary">العودة للمنتج</a>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script>
    function toggleReviewForm(showForm) {
      var reviewsList = document.getElementById('reviewsList');
      var writeReview = document.getElementById('writeReview');
      var heroBtn = document.getElementById('heroWriteReviewBtn');
      if (showForm) {
        reviewsList.style.display = 'none';
        if (heroBtn) heroBtn.style.display = 'none';
        writeReview.style.display = 'block';
        writeReview.scrollIntoView({ behavior: 'smooth' });
      } else {
        reviewsList.style.display = '';
        if (heroBtn) heroBtn.style.display = '';
        writeReview.style.display = 'none';
        reviewsList.scrollIntoView({ behavior: 'smooth' });
      }
    }
  </script>
  <script>
    // Override review form to submit via fetch with FormData
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('reviewForm');
      if (!form) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        e.stopImmediatePropagation();

        // Clear previous errors
        clearErrors();

        const name = document.getElementById('reviewName');
        const phone = document.getElementById('reviewPhone');
        const message = document.getElementById('reviewMessage');
        const rating = document.getElementById('reviewRating');

        let isValid = true;

        if (!name.value.trim()) {
          showFieldError(name, 'يرجى إدخال الاسم');
          isValid = false;
        }

        if (!phone.value.trim()) {
          showFieldError(phone, 'يرجى إدخال رقم الهاتف');
          isValid = false;
        } else if (!/^\d{9,10}$/.test(phone.value.trim().replace(/\s/g, ''))) {
          showFieldError(phone, 'رقم الهاتف غير صالح');
          isValid = false;
        }

        if (!message.value.trim()) {
          showFieldError(message, 'يرجى كتابة تقييمك');
          isValid = false;
        }

        if (!isValid) {
          showToast('يرجى تعبئة الحقول المطلوبة', 'error');
          return;
        }

        const formData = new FormData();
        formData.append('name', name.value.trim());
        formData.append('phone', phone.value.trim());
        formData.append('rating', rating.value);
        formData.append('message', message.value.trim());

        // Append image if selected
        const imageInput = document.getElementById('reviewImage');
        if (imageInput && imageInput.files && imageInput.files.length > 0) {
          formData.append('image', imageInput.files[0]);
        }

        // Append audio if recorded
        const audioEl = document.getElementById('reviewVoiceAudio');
        if (audioEl && audioEl.src && audioEl.src.startsWith('blob:')) {
          try {
            const audioResp = await fetch(audioEl.src);
            const audioBlob = await audioResp.blob();
            formData.append('audio', audioBlob, 'voice-review.webm');
          } catch (err) {
            console.warn('Could not attach audio:', err);
          }
        }

        try {
          const response = await fetch('/product/<%= product.slug %>/review', {
            method: 'POST',
            body: formData
          });

          const data = await response.json();

          if (data.success) {
            form.style.display = 'none';
            const success = document.getElementById('reviewSuccess');
            success.classList.add('visible');
            showToast('شكراً! تم إرسال تقييمك بنجاح', 'success');
          } else {
            showToast(data.error || 'حدث خطأ، يرجى المحاولة مرة أخرى', 'error');
          }
        } catch (err) {
          console.error('Review submission error:', err);
          showToast('حدث خطأ في الاتصال، يرجى المحاولة مرة أخرى', 'error');
        }
      }, true);
    });
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
