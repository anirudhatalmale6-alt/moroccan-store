<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <title><%= (product.meta_title ? product.meta_title : product.title) %> — <%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></title>
  <%- include('partials/head') %>
  <% if (product.meta_description) { %><meta name="description" content="<%= product.meta_description %>"><% } %>
  <% if (product.meta_title || product.title) { %><meta property="og:title" content="<%= product.meta_title || product.title %>"><% } %>
  <% if (product.meta_description || product.description) { %><meta property="og:description" content="<%= product.meta_description || (product.description || '').substring(0, 200) %>"><% } %>
  <% if (product.main_image) { %><meta property="og:image" content="/uploads/products/<%= product.main_image %>"><% } %>
</head>
<body>

  <div class="pattern-overlay"></div>

  <!-- Audio Autoplay -->
  <% if (product.audio_filename && product.audio_autoplay) { %>
  <audio id="productAudio" src="/uploads/products/<%= product.audio_filename %>" autoplay loop></audio>
  <button type="button" id="audioToggleBtn" onclick="toggleProductAudio()" style="
    position: fixed; bottom: 20px; left: 20px; z-index: 9999;
    width: 48px; height: 48px; border-radius: 50%;
    background: var(--color-primary); color: #fff; border: none;
    font-size: 20px; cursor: pointer; box-shadow: var(--shadow-md);
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition-fast);
  ">🔊</button>
  <% } %>

  <!-- Navbar -->
  <%- include('partials/navbar', { product }) %>

  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero__grid">
        <div class="hero__content">
          <% var prodAvail = product.availability_status || 'in_stock'; %>
          <% if (prodAvail === 'out_of_stock') { %>
          <div class="hero__badge" style="background: rgba(198,40,40,0.1); color: #c62828;">
            <span class="hero__badge-dot" style="background: #c62828;"></span>
            غير متوفر حاليا
          </div>
          <% } else if (prodAvail === 'preorder') { %>
          <div class="hero__badge" style="background: rgba(245,127,23,0.1); color: #f57f17;">
            <span class="hero__badge-dot" style="background: #f57f17;"></span>
            طلب مسبق — سيتم الشحن قريبا
          </div>
          <% } else { %>
          <div class="hero__badge">
            <span class="hero__badge-dot"></span>
            متوفر الآن — توصيل لجميع المدن
          </div>
          <% } %>
          <h1 class="hero__title">
            <%= product.title %>
          </h1>
          <a href="/product/<%= product.slug %>/reviews" class="hero__rating">
            <span class="hero__rating-stars"><% for (let i = 1; i <= 5; i++) { %><%= i <= Math.round(avgRating) ? '★' : '☆' %><% } %></span>
            <span class="hero__rating-count"><%= avgRating %> — <%= reviewCount %> تقييم</span>
            <span class="hero__rating-link">شاهد التقييمات ←</span>
          </a>
          <p class="hero__desc">
            <%= product.description %>
          </p>

          <!-- Variations -->
          <% if (typeof sizeVariations !== 'undefined' && sizeVariations && sizeVariations.length > 0) { %>
          <div class="product-variations" style="margin-top: 12px; margin-bottom: 8px;">
            <label style="display: block; font-weight: 700; font-size: 14px; margin-bottom: 8px; color: var(--color-primary-dark);">اختر الحجم:</label>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
              <% sizeVariations.forEach(function(v, idx) { %>
                <button type="button" class="variation-btn size-variation-btn<%= idx === 0 ? ' active' : '' %>"
                  data-variation-id="<%= v.id %>"
                  data-price-adjustment="<%= v.price_adjustment %>"
                  onclick="selectSizeVariation(this)"
                  style="
                    padding: 8px 16px; border-radius: 50px; border: 2px solid var(--color-border);
                    background: var(--color-card); cursor: pointer; font-family: var(--font-body);
                    font-size: 13px; font-weight: 700; color: var(--color-text);
                    transition: var(--transition-fast); min-width: 42px; text-align: center;
                  "><%= v.label %>
                  <% if (v.price_adjustment > 0) { %><span style="font-size: 11px; color: var(--color-text-muted);"> (+<%= v.price_adjustment %> د.م)</span><% } %>
                  <% if (v.price_adjustment < 0) { %><span style="font-size: 11px; color: var(--color-success);"> (<%= v.price_adjustment %> د.م)</span><% } %>
                </button>
              <% }); %>
            </div>
          </div>
          <% } %>

          <% if (typeof colorVariations !== 'undefined' && colorVariations && colorVariations.length > 0) { %>
          <div class="product-variations" style="margin-top: 8px; margin-bottom: 8px;">
            <label style="display: block; font-weight: 700; font-size: 14px; margin-bottom: 8px; color: var(--color-primary-dark);">اختر اللون:</label>
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
              <% colorVariations.forEach(function(v, idx) { %>
                <button type="button" class="variation-btn color-variation-btn<%= idx === 0 ? ' active' : '' %>"
                  data-variation-id="<%= v.id %>"
                  data-price-adjustment="<%= v.price_adjustment %>"
                  onclick="selectColorVariation(this)"
                  title="<%= v.label %>"
                  style="
                    width: 40px; height: 40px; border-radius: 50%; border: 2px solid var(--color-border);
                    cursor: pointer; padding: 0; overflow: hidden; position: relative;
                    transition: var(--transition-fast);
                    <% if (v.image_filename) { %>
                      background-image: url('/uploads/variations/<%= v.image_filename %>');
                      background-size: cover; background-position: center;
                    <% } else if (v.value) { %>
                      background-color: <%= v.value %>;
                    <% } else { %>
                      background-color: #ccc;
                    <% } %>
                  ">
                </button>
              <% }); %>
            </div>
            <div id="selectedColorLabel" style="margin-top: 6px; font-size: 13px; color: var(--color-text-secondary);">
              <% if (colorVariations.length > 0) { %><%= colorVariations[0].label %><% } %>
            </div>
          </div>
          <% } %>

          <div class="hero__price" id="heroPrice">
            <span class="hero__price-current" id="currentPrice"><%= product.price %> درهم</span>
            <% if (product.old_price) { %>
              <span class="hero__price-old"><%= product.old_price %> درهم</span>
            <% } %>
            <% if (product.discount) { %>
              <span class="hero__price-badge">-<%= product.discount %>%</span>
            <% } %>
          </div>
          <% if (product.stock_quantity !== null && product.stock_quantity >= 0 && product.stock_quantity <= 10) { %>
            <div style="font-size: 13px; font-weight: 700; color: #c62828; margin-top: 4px; margin-bottom: 4px;"><%= product.stock_quantity === 0 ? 'نفذت الكمية!' : 'باقي ' + product.stock_quantity + ' قطع فقط!' %></div>
          <% } %>
          <div class="hero__actions" style="display: flex; gap: 12px; flex-wrap: wrap;">
            <% if (prodAvail !== 'out_of_stock' && (product.stock_quantity === null || product.stock_quantity < 0 || product.stock_quantity > 0)) { %>
            <a href="/product/<%= product.slug %>/checkout" id="buyNowBtn" class="btn btn--primary btn--lg">
              اشتري الآن 🛍️
            </a>
            <button type="button" class="btn btn--outline btn--lg" id="addToCartBtn" onclick="addToCartFromProduct()">
              أضف للسلة 🛒
            </button>
            <% } else { %>
            <button type="button" class="btn btn--lg" style="background: #ccc; color: #666; cursor: not-allowed;" disabled>غير متوفر حاليا</button>
            <% } %>
          </div>
        </div>
        <div class="hero__image">
          <div class="hero__image-decorator"></div>
          <div class="hero__image-wrapper">
            <% if (product.main_image) { %>
              <img src="/uploads/products/<%= product.main_image %>" alt="<%= product.title %>" style="width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-lg);">
            <% } else if (product.video_filename) { %>
              <video class="hero__video" autoplay muted loop playsinline poster="">
                <source src="/uploads/products/<%= product.video_filename %>" type="video/mp4">
              </video>
              <div class="hero__video-fallback">🧴</div>
              <div class="hero__video-overlay"></div>
            <% } else { %>
              <div class="hero__image-placeholder">🧴</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Description Images Section (Landing-page style, full-width) -->
  <%
    var descImages = [];
    try { descImages = JSON.parse(product.description_images || '[]'); } catch(e) {}
  %>
  <% if (descImages && descImages.length > 0) { %>
  <section class="description-images-section" style="padding: 0; margin: 16px 0 0 0;">
    <div style="max-width: 900px; margin: 0 auto; padding: 0 16px;">
      <% descImages.forEach(function(imgFile) { %>
        <div style="margin-bottom: 0; text-align: center;">
          <img src="/uploads/products/<%= imgFile %>" alt="<%= product.title %>"
            style="width: 100%; max-width: 100%; height: auto; display: block; margin: 0 auto;" loading="lazy">
        </div>
      <% }); %>
    </div>
  </section>
  <% } %>

  <!-- Features Section -->
  <% if (product.features && product.features.length) { %>
  <section class="features" id="features">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-header__label">لماذا منتجنا؟</span>
        <h2 class="section-header__title">مميزات تجعله الخيار الأفضل</h2>
        <div class="section-header__divider"></div>
      </div>
      <div class="features__grid">
        <% product.features.forEach(function(feature) { %>
          <div class="feature-card animate-on-scroll">
            <div class="feature-card__icon"><span><%= feature.icon %></span></div>
            <h3 class="feature-card__title"><%= feature.title %></h3>
            <p class="feature-card__desc"><%= feature.desc %></p>
          </div>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Gallery Section -->
  <% if (product.show_gallery && galleryImages && galleryImages.length > 0) { %>
  <section class="gallery">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-header__label">صور المنتج</span>
        <h2 class="section-header__title">شاهد المنتج من كل الزوايا</h2>
        <div class="section-header__divider"></div>
      </div>
      <div class="gallery__grid">
        <% galleryImages.forEach(function(img) { %>
          <div class="gallery__item animate-on-scroll">
            <img src="/uploads/products/<%= img.filename %>" alt="<%= product.title %>" style="width:100%; height:100%; object-fit:cover; border-radius: var(--radius-md);" loading="lazy">
          </div>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- FAQ Section -->
  <% if (typeof faqs !== 'undefined' && faqs && faqs.length > 0) { %>
  <section class="faq-section" id="faq">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-header__label">أسئلة شائعة</span>
        <h2 class="section-header__title">الأسئلة المتكررة</h2>
        <div class="section-header__divider"></div>
      </div>
      <div class="faq-list" style="max-width: 800px; margin: 0 auto;">
        <% faqs.forEach(function(faq, idx) { %>
          <div class="faq-item animate-on-scroll" style="background: var(--color-bg-card, #fff); border-radius: var(--radius-md, 16px); margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); overflow: hidden;">
            <button type="button" class="faq-question" onclick="toggleFaq(this)" style="width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; border: none; background: none; cursor: pointer; font-family: inherit; font-size: 16px; font-weight: 700; color: var(--color-primary, #6B5335); text-align: right; gap: 16px; direction: rtl;">
              <span><%= faq.question %></span>
              <span class="faq-arrow" style="font-size: 20px; transition: transform 0.3s; flex-shrink: 0;">▼</span>
            </button>
            <div class="faq-answer" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease;">
              <div style="padding: 0 24px 20px; color: var(--color-text, #555); font-size: 15px; line-height: 1.8;">
                <%= faq.answer %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Reviews Section -->
  <% if (typeof product.show_reviews === 'undefined' || product.show_reviews) { %>
  <section class="trust">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-header__label">آراء العملاء</span>
        <h2 class="section-header__title">ماذا يقول عملاؤنا</h2>
        <div class="section-header__divider"></div>
      </div>
      <div style="text-align: center; margin-bottom: 24px;">
        <button type="button" class="btn btn--primary" id="showFeedbackFormBtn" onclick="toggleFeedbackView(true)">اكتب تقييمك</button>
      </div>
      <div id="reviewsDisplay">
      <% if (reviews && reviews.length) { %>
        <div class="trust__grid">
          <% reviews.forEach(function(review) { %>
            <div class="trust-card animate-on-scroll">
              <div class="trust-card__author" style="margin-bottom: 12px;">
                <div class="trust-card__avatar" style="font-size: 24px; display: flex; align-items: center; justify-content: center;"><%= (function(n){ var e=['😊','😎','🤩','😇','🥰','😄','🤗','😺','🦊','🐻','🐶','🐱','🐸','🦁','🐼','🐯','🐨','🦋','🌸','⭐']; var h=0; for(var i=0;i<n.length;i++) h=((h<<5)-h)+n.charCodeAt(i); return e[Math.abs(h)%e.length]; })(review.name) %></div>
                <div>
                  <div class="trust-card__name" style="display: flex; align-items: center; gap: 6px;"><%= review.name %> <span style="background: var(--color-success); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 4px; white-space: nowrap;">✓ موثّق</span></div>
                </div>
              </div>
              <div class="trust-card__stars">
                <% for (let i = 1; i <= 5; i++) { %><%= i <= review.rating ? '★' : '☆' %><% } %>
              </div>
              <p class="trust-card__text">"<%= review.message %>"</p>
              <% if (review.image_filename) { %>
                <div style="margin-bottom: 16px; text-align: center;">
                  <img src="/uploads/reviews/<%= review.image_filename %>" alt="صورة من <%= review.name %>" style="max-width: 100%; border-radius: var(--radius-sm); max-height: 200px; object-fit: cover;" loading="lazy">
                </div>
              <% } %>
              <% if (review.audio_filename && review.audio_filename.length > 0) { %>
                <div class="wa-audio-player" data-src="/uploads/reviews/<%= review.audio_filename %>">
                  <button type="button" class="wa-play-btn" onclick="toggleWaAudio(this)">▶</button>
                  <div class="wa-progress-wrap" onclick="seekWaAudio(event, this)">
                    <div class="wa-waveform"></div>
                  </div>
                  <span class="wa-time">0:00</span>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div style="text-align: center; padding: 40px 0; color: var(--color-text-muted);">
          <p style="font-size: 18px; margin-bottom: 8px;">لا توجد تقييمات بعد</p>
          <p style="font-size: 14px;">كن أول من يشارك تجربته!</p>
        </div>
      <% } %>
      </div>
    </div>
  </section>

  <!-- Feedback Submission Section -->
  <section class="feedback-section" id="feedback" style="display: none;">
    <div class="container container--narrow">
      <div style="text-align: center; margin-bottom: 24px;">
        <button type="button" class="btn btn--outline" onclick="toggleFeedbackView(false)">العودة للتقييمات</button>
      </div>
      <div class="section-header animate-on-scroll">
        <span class="section-header__label">شاركنا رأيك</span>
        <h2 class="section-header__title">نحب نسمعو منك!</h2>
        <div class="section-header__divider"></div>
      </div>
      <div class="feedback-card animate-on-scroll">
        <form id="feedbackForm" class="feedback-form" data-slug="<%= product.slug %>" action="/product/<%= product.slug %>/review" method="POST" enctype="multipart/form-data">
          <div class="feedback-form__row">
            <div class="form-group">
              <label class="form-label" for="feedbackName">
                <span class="required">*</span> الاسم
              </label>
              <input type="text" id="feedbackName" name="name" class="form-input" placeholder="أدخل اسمك" required>
              <div class="form-error">يرجى إدخال الاسم</div>
            </div>
            <div class="form-group">
              <label class="form-label" for="feedbackPhone">
                <span class="required">*</span> رقم الهاتف
              </label>
              <input type="tel" id="feedbackPhone" name="phone" class="form-input" placeholder="0612345678" required dir="ltr" style="text-align: left;">
              <div class="form-error">يرجى إدخال رقم الهاتف</div>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">التقييم</label>
            <div class="feedback-stars" id="feedbackStars">
              <span class="feedback-star" data-rating="1">☆</span>
              <span class="feedback-star" data-rating="2">☆</span>
              <span class="feedback-star" data-rating="3">☆</span>
              <span class="feedback-star" data-rating="4">☆</span>
              <span class="feedback-star" data-rating="5">☆</span>
            </div>
            <input type="hidden" id="feedbackRating" name="rating" value="5">
          </div>
          <div class="form-group">
            <label class="form-label" for="feedbackMessage">
              <span class="required">*</span> تعليقك
            </label>
            <textarea id="feedbackMessage" name="message" class="form-input form-textarea" placeholder="اكتب تجربتك مع المنتج أو أي ملاحظة..." rows="4" required></textarea>
            <div class="form-error">يرجى كتابة تعليقك</div>
          </div>
          <!-- Image Upload -->
          <div class="form-group">
            <label class="form-label">صورة (اختياري)</label>
            <div class="feedback-upload-zone" id="feedbackImageZone">
              <div class="feedback-upload-zone__icon">📷</div>
              <div class="feedback-upload-zone__text">اضغط لرفع صورة</div>
              <div class="feedback-upload-zone__hint">JPG, PNG — الحد الأقصى 5MB</div>
              <input type="file" id="feedbackImage" name="image" accept="image/*">
            </div>
            <div class="feedback-upload-preview" id="feedbackImagePreview">
              <button type="button" class="feedback-upload-preview__remove" data-target="feedbackImage">✕</button>
              <img class="feedback-upload-preview__img" src="" alt="معاينة">
              <div class="feedback-upload-preview__name"></div>
            </div>
          </div>
          <!-- Voice Recording -->
          <div class="form-group">
            <label class="form-label">تعليق صوتي (اختياري)</label>
            <div class="voice-recorder" id="voiceRecorder">
              <button type="button" class="voice-recorder__btn" id="voiceRecordBtn">
                <span class="voice-recorder__icon">🎙️</span>
                <span class="voice-recorder__label">اضغط للتسجيل</span>
              </button>
              <div class="voice-recorder__status" id="voiceStatus"></div>
              <div class="voice-recorder__player" id="voicePlayer">
                <audio id="voiceAudio" controls></audio>
                <button type="button" class="voice-recorder__remove" id="voiceRemoveBtn">حذف</button>
              </div>
            </div>
          </div>
          <button type="submit" class="btn btn--primary">
            إرسال التعليق
          </button>
          <p class="feedback-form__note">سيتم مراجعة تعليقك قبل نشره</p>
        </form>
        <!-- Success state (hidden by default) -->
        <div class="feedback-success" id="feedbackSuccess">
          <div class="feedback-success__icon">✅</div>
          <h3 class="feedback-success__title">شكراً على تعليقك!</h3>
          <p class="feedback-success__text">تم إرسال تعليقك بنجاح. سيتم مراجعته ونشره قريباً.</p>
          <button type="button" class="btn btn--outline" onclick="resetFeedbackForm()">إرسال تعليق آخر</button>
        </div>
      </div>
    </div>
  </section>
  <% } /* end show_reviews */ %>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-section__inner animate-on-scroll">
        <h2 class="cta-section__title">لا تفوّت العرض المحدود!</h2>
        <p class="cta-section__desc">
          احصل على منتجك اليوم بسعر مخفض مع توصيل سريع لجميع مدن المغرب
        </p>
        <a href="/product/<%= product.slug %>/checkout" class="btn btn--primary btn--lg">
          اطلب الآن — <%= product.price %> درهم فقط
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <%- include('partials/footer') %>

  <style>
    .variation-btn.active {
      border-color: var(--color-primary) !important;
      box-shadow: 0 0 0 2px var(--color-primary-light);
    }
    .color-variation-btn.active {
      border-color: var(--color-primary) !important;
      box-shadow: 0 0 0 3px var(--color-primary-light);
      transform: scale(1.1);
    }
  </style>

  <script>
    var PRODUCT_BASE_PRICE = <%= product.price %>;
    var PRODUCT_SLUG = '<%= product.slug %>';
    var PRODUCT_ID = <%= product.id %>;
    var selectedSizeId = null;
    var selectedColorId = null;
    var sizePriceAdj = 0;
    var colorPriceAdj = 0;

    // Initialize default selections
    (function() {
      var firstSize = document.querySelector('.size-variation-btn');
      if (firstSize) {
        selectedSizeId = parseInt(firstSize.dataset.variationId);
        sizePriceAdj = parseFloat(firstSize.dataset.priceAdjustment) || 0;
      }
      var firstColor = document.querySelector('.color-variation-btn');
      if (firstColor) {
        selectedColorId = parseInt(firstColor.dataset.variationId);
        colorPriceAdj = parseFloat(firstColor.dataset.priceAdjustment) || 0;
      }
    })();

    function selectSizeVariation(btn) {
      document.querySelectorAll('.size-variation-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      selectedSizeId = parseInt(btn.dataset.variationId);
      sizePriceAdj = parseFloat(btn.dataset.priceAdjustment) || 0;
      updateDisplayedPrice();
    }

    function selectColorVariation(btn) {
      document.querySelectorAll('.color-variation-btn').forEach(function(b) { b.classList.remove('active'); });
      btn.classList.add('active');
      selectedColorId = parseInt(btn.dataset.variationId);
      colorPriceAdj = parseFloat(btn.dataset.priceAdjustment) || 0;
      var label = document.getElementById('selectedColorLabel');
      if (label) label.textContent = btn.title;
      updateDisplayedPrice();
    }

    function updateDisplayedPrice() {
      var total = PRODUCT_BASE_PRICE + sizePriceAdj + colorPriceAdj;
      var priceEl = document.getElementById('currentPrice');
      if (priceEl) priceEl.textContent = total + ' درهم';
    }

    function addToCartFromProduct() {
      var btn = document.getElementById('addToCartBtn');
      btn.disabled = true;
      btn.innerHTML = 'جاري الإضافة...';

      fetch('/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          product_id: PRODUCT_ID,
          quantity: 1,
          size_variation_id: selectedSizeId,
          color_variation_id: selectedColorId
        })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          showToast('تمت إضافة المنتج للسلة', 'success');
          // Update cart badge if exists
          var badge = document.getElementById('cartBadge');
          if (badge) {
            badge.textContent = data.cartCount || '';
            badge.style.display = (data.cartCount > 0) ? 'flex' : 'none';
          }
        } else {
          showToast(data.error || 'حدث خطأ', 'error');
        }
        btn.disabled = false;
        btn.innerHTML = 'أضف للسلة 🛒';
      })
      .catch(function(err) {
        showToast('حدث خطأ في الاتصال', 'error');
        btn.disabled = false;
        btn.innerHTML = 'أضف للسلة 🛒';
      });
    }

    function toggleProductAudio() {
      var audio = document.getElementById('productAudio');
      var btn = document.getElementById('audioToggleBtn');
      if (!audio) return;
      if (audio.muted || audio.paused) {
        audio.muted = false;
        audio.play().catch(function(){});
        btn.textContent = '🔊';
      } else {
        audio.muted = true;
        btn.textContent = '🔇';
      }
    }

    // Auto-play with muted first (browsers require user interaction for unmuted autoplay)
    (function() {
      var audio = document.getElementById('productAudio');
      if (audio) {
        audio.muted = true;
        audio.play().then(function() {
          // Auto-play succeeded muted, try unmuted after user interaction
          document.addEventListener('click', function unmute() {
            audio.muted = false;
            var btn = document.getElementById('audioToggleBtn');
            if (btn) btn.textContent = '🔊';
            document.removeEventListener('click', unmute);
          }, { once: true });
        }).catch(function(){});
      }
    })();

    function toggleFaq(btn) {
      var item = btn.parentElement;
      var answer = item.querySelector('.faq-answer');
      var arrow = btn.querySelector('.faq-arrow');
      var isOpen = answer.style.maxHeight && answer.style.maxHeight !== '0px';
      if (isOpen) {
        answer.style.maxHeight = '0';
        arrow.style.transform = 'rotate(0deg)';
      } else {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        arrow.style.transform = 'rotate(180deg)';
      }
    }

    function toggleFeedbackView(showForm) {
      var reviewsDisplay = document.getElementById('reviewsDisplay');
      var feedbackSection = document.getElementById('feedback');
      var showBtn = document.getElementById('showFeedbackFormBtn');
      if (showForm) {
        reviewsDisplay.style.display = 'none';
        showBtn.style.display = 'none';
        feedbackSection.style.display = 'block';
        feedbackSection.scrollIntoView({ behavior: 'smooth' });
      } else {
        reviewsDisplay.style.display = '';
        showBtn.style.display = '';
        feedbackSection.style.display = 'none';
        document.querySelector('.trust').scrollIntoView({ behavior: 'smooth' });
      }
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
