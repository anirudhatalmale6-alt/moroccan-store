<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>التعليقات — لوحة التحكم</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Cairo', sans-serif;
            background: #f5f1ed;
            direction: rtl;
            text-align: right;
            min-height: 100vh;
        }
        .admin-wrapper { display: flex; min-height: 100vh; }
        .sidebar {
            width: 260px; background: #6B5335; color: #fff;
            position: fixed; top: 0; right: 0; bottom: 0; z-index: 100;
            display: flex; flex-direction: column; transition: transform 0.3s;
        }
        .sidebar-header { padding: 28px 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-header h2 { font-size: 20px; font-weight: 700; }
        .sidebar-header p { font-size: 12px; opacity: 0.6; margin-top: 2px; }
        .sidebar-nav { list-style: none; padding: 16px 0; flex: 1; }
        .sidebar-nav li a {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 24px; color: rgba(255,255,255,0.75);
            text-decoration: none; font-size: 15px; font-weight: 600; transition: all 0.2s;
        }
        .sidebar-nav li a:hover, .sidebar-nav li a.active { background: rgba(255,255,255,0.1); color: #fff; }
        .sidebar-nav li a.active { border-left: 3px solid #fff; }
        .sidebar-nav li a svg { width: 20px; height: 20px; fill: currentColor; flex-shrink: 0; }
        .sidebar-footer { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
        .sidebar-footer a { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 600; transition: color 0.2s; }
        .sidebar-footer a:hover { color: #fff; }
        .sidebar-footer a svg { width: 20px; height: 20px; fill: currentColor; }
        .main-content { flex: 1; margin-right: 260px; padding: 32px; }
        .page-title { font-size: 26px; font-weight: 700; color: #6B5335; margin-bottom: 24px; }
        /* Filter Tabs */
        .filter-tabs { display: flex; gap: 8px; margin-bottom: 24px; flex-wrap: wrap; }
        .filter-tab {
            display: inline-block; padding: 8px 20px; border-radius: 10px;
            font-family: 'Cairo', sans-serif; font-size: 14px; font-weight: 700;
            text-decoration: none; color: #8B6F47; background: #fff;
            border: 2px solid #e8e0d8; transition: all 0.2s;
        }
        .filter-tab:hover { border-color: #8B6F47; }
        .filter-tab.active { background: #8B6F47; color: #fff; border-color: #8B6F47; }
        /* Review Cards */
        .reviews-list { display: flex; flex-direction: column; gap: 16px; }
        .review-card {
            background: #fff; border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04); padding: 24px;
        }
        .review-card-header {
            display: flex; align-items: flex-start; justify-content: space-between;
            margin-bottom: 12px; flex-wrap: wrap; gap: 12px;
        }
        .review-meta { flex: 1; }
        .review-name {
            font-size: 16px; font-weight: 700; color: #333; margin-bottom: 2px;
        }
        .review-product {
            font-size: 13px; color: #999; font-weight: 600;
        }
        .review-stars { display: flex; gap: 2px; margin-top: 6px; }
        .star { font-size: 18px; color: #ddd; }
        .star.filled { color: #f0a500; }
        .badge {
            display: inline-block; padding: 4px 14px; border-radius: 20px;
            font-size: 12px; font-weight: 700; flex-shrink: 0;
        }
        .badge-pending { background: #fff3e0; color: #e65100; }
        .badge-approved { background: #e8f5e9; color: #2e7d32; }
        .badge-rejected { background: #ffebee; color: #c62828; }
        .review-message {
            font-size: 14px; color: #555; line-height: 1.8;
            margin-bottom: 16px; padding: 16px;
            background: #faf8f5; border-radius: 10px;
        }
        /* Media */
        .review-media { display: flex; gap: 16px; margin-bottom: 16px; flex-wrap: wrap; align-items: flex-start; }
        .review-thumb {
            width: 120px; height: 120px; object-fit: cover;
            border-radius: 10px; border: 2px solid #e8e0d8; cursor: pointer;
        }
        .review-thumb:hover { border-color: #8B6F47; }
        .review-audio {
            flex: 1; min-width: 250px;
        }
        .review-audio audio {
            width: 100%; border-radius: 8px;
        }
        /* Actions */
        .review-card-actions {
            display: flex; gap: 8px; flex-wrap: wrap; padding-top: 16px;
            border-top: 1px solid #f0ebe5;
        }
        .btn {
            display: inline-block; padding: 8px 18px; border: none; border-radius: 8px;
            font-family: 'Cairo', sans-serif; font-size: 13px; font-weight: 700;
            cursor: pointer; text-decoration: none; transition: opacity 0.2s;
        }
        .btn:hover { opacity: 0.85; }
        .btn-approve { background: #e8f5e9; color: #2e7d32; }
        .btn-reject { background: #fff3e0; color: #e65100; }
        .btn-delete { background: #ffebee; color: #c62828; }
        .empty-state { padding: 60px 40px; text-align: center; color: #bbb; font-size: 14px; background: #fff; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
        .mobile-toggle {
            display: none; position: fixed; top: 16px; right: 16px; z-index: 200;
            background: #6B5335; color: #fff; border: none; border-radius: 10px;
            width: 44px; height: 44px; font-size: 20px; cursor: pointer;
        }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 90; }
        @media (max-width: 768px) {
            .mobile-toggle { display: block; }
            .sidebar { transform: translateX(100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main-content { margin-right: 0; padding: 24px 16px; padding-top: 72px; }
            .review-card { padding: 20px; }
            .review-card-header { flex-direction: column; }
            .review-media { flex-direction: column; }
            .review-thumb { width: 100%; height: 200px; }
        }
    </style>
</head>
<body>
    <button class="mobile-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open'); document.querySelector('.sidebar-overlay').classList.toggle('open');">&#9776;</button>
    <div class="sidebar-overlay" onclick="document.querySelector('.sidebar').classList.remove('open'); this.classList.remove('open');"></div>

    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>لوحة التحكم</h2>
                <p>ادارة المتجر</p>
            </div>
            <ul class="sidebar-nav">
                <li><a href="/admin">
                    <svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                    الرئيسية
                </a></li>
                <li><a href="/admin/products">
                    <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V6h16v12zM6 10h2v2H6zm0 4h8v2H6zm10 0h2v2h-2zm-6-4h8v2h-8z"/></svg>
                    المنتجات
                </a></li>
                <li><a href="/admin/orders">
                    <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10H7v-2h10v2z"/></svg>
                    الطلبات
                </a></li>
                <li><a href="/admin/reviews" class="active">
                    <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
                    التعليقات
                </a></li>
            </ul>
            <div class="sidebar-footer">
                <a href="/admin/logout">
                    <svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                    تسجيل الخروج
                </a>
            </div>
        </aside>

        <main class="main-content">
            <h1 class="page-title">التعليقات</h1>

            <!-- Filter Tabs -->
            <div class="filter-tabs">
                <a href="/admin/reviews" class="filter-tab <%= (!currentStatus || currentStatus === 'all') ? 'active' : '' %>">الكل</a>
                <a href="/admin/reviews?status=pending" class="filter-tab <%= currentStatus === 'pending' ? 'active' : '' %>">معلقة</a>
                <a href="/admin/reviews?status=approved" class="filter-tab <%= currentStatus === 'approved' ? 'active' : '' %>">مقبولة</a>
                <a href="/admin/reviews?status=rejected" class="filter-tab <%= currentStatus === 'rejected' ? 'active' : '' %>">مرفوضة</a>
            </div>

            <% if (reviews && reviews.length > 0) { %>
                <div class="reviews-list">
                    <% reviews.forEach(function(review) { %>
                        <div class="review-card">
                            <div class="review-card-header">
                                <div class="review-meta">
                                    <div class="review-name"><%= review.name %></div>
                                    <div class="review-product">على: <%= review.product_title %></div>
                                    <% if (review.rating) { %>
                                        <div class="review-stars">
                                            <% for (var i = 1; i <= 5; i++) { %>
                                                <span class="star <%= i <= review.rating ? 'filled' : '' %>">&#9733;</span>
                                            <% } %>
                                        </div>
                                    <% } %>
                                </div>
                                <span class="badge badge-<%= review.status %>">
                                    <%= review.status === 'pending' ? 'معلق' : review.status === 'approved' ? 'مقبول' : 'مرفوض' %>
                                </span>
                            </div>

                            <% if (review.message) { %>
                                <div class="review-message"><%= review.message %></div>
                            <% } %>

                            <% if (review.image_filename || review.audio_filename) { %>
                                <div class="review-media">
                                    <% if (review.image_filename) { %>
                                        <a href="/uploads/reviews/<%= review.image_filename %>" target="_blank">
                                            <img src="/uploads/reviews/<%= review.image_filename %>" alt="صورة التعليق" class="review-thumb">
                                        </a>
                                    <% } %>
                                    <% if (review.audio_filename) { %>
                                        <div class="review-audio">
                                            <audio controls preload="none">
                                                <source src="/uploads/reviews/<%= review.audio_filename %>">
                                                المتصفح لا يدعم تشغيل الصوت
                                            </audio>
                                        </div>
                                    <% } %>
                                </div>
                            <% } %>

                            <div class="review-card-actions">
                                <% if (review.status !== 'approved') { %>
                                    <form method="POST" action="/admin/reviews/<%= review.id %>/approve" style="display:inline;">
                                        <button type="submit" class="btn btn-approve">قبول</button>
                                    </form>
                                <% } %>
                                <% if (review.status !== 'rejected') { %>
                                    <form method="POST" action="/admin/reviews/<%= review.id %>/reject" style="display:inline;">
                                        <button type="submit" class="btn btn-reject">رفض</button>
                                    </form>
                                <% } %>
                                <form method="POST" action="/admin/reviews/<%= review.id %>/delete" style="display:inline;" onclick="return confirm('هل أنت متأكد من حذف هذا التعليق؟')">
                                    <button type="submit" class="btn btn-delete">حذف</button>
                                </form>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-state">لا توجد تعليقات<%= currentStatus && currentStatus !== 'all' ? ' بهذه الحالة' : '' %></div>
            <% } %>
        </main>
    </div>
</body>
</html>
