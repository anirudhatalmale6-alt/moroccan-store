<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تفاصيل الطلب #<%= order.order_ref %> — لوحة التحكم</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Cairo', sans-serif;
            background: #f5f1ed;
            direction: rtl;
            text-align: right;
            min-height: 100vh;
        }
        .admin-wrapper { display: flex; min-height: 100vh; }
        .sidebar {
            width: 260px; background: #6B5335; color: #fff;
            position: fixed; top: 0; right: 0; bottom: 0; z-index: 100;
            display: flex; flex-direction: column; transition: transform 0.3s;
        }
        .sidebar-header { padding: 28px 24px 20px; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .sidebar-header h2 { font-size: 20px; font-weight: 700; }
        .sidebar-header p { font-size: 12px; opacity: 0.6; margin-top: 2px; }
        .sidebar-nav { list-style: none; padding: 16px 0; flex: 1; }
        .sidebar-nav li a {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 24px; color: rgba(255,255,255,0.75);
            text-decoration: none; font-size: 15px; font-weight: 600; transition: all 0.2s;
        }
        .sidebar-nav li a:hover, .sidebar-nav li a.active { background: rgba(255,255,255,0.1); color: #fff; }
        .sidebar-nav li a.active { border-left: 3px solid #fff; }
        .sidebar-nav li a svg { width: 20px; height: 20px; fill: currentColor; flex-shrink: 0; }
        .sidebar-footer { padding: 16px 24px; border-top: 1px solid rgba(255,255,255,0.1); }
        .sidebar-footer a { display: flex; align-items: center; gap: 12px; color: rgba(255,255,255,0.6); text-decoration: none; font-size: 14px; font-weight: 600; transition: color 0.2s; }
        .sidebar-footer a:hover { color: #fff; }
        .sidebar-footer a svg { width: 20px; height: 20px; fill: currentColor; }
        .main-content { flex: 1; margin-right: 260px; padding: 32px; }
        .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; flex-wrap: wrap; gap: 12px; }
        .page-title { font-size: 26px; font-weight: 700; color: #6B5335; }
        .btn {
            display: inline-block; padding: 10px 24px; border: none; border-radius: 10px;
            font-family: 'Cairo', sans-serif; font-size: 14px; font-weight: 700;
            cursor: pointer; text-decoration: none; transition: opacity 0.2s;
        }
        .btn:hover { opacity: 0.85; }
        .btn-primary { background: #8B6F47; color: #fff; }
        .btn-secondary { background: #e8e0d8; color: #6B5335; }
        .btn-delete { background: #c62828; color: #fff; }
        .btn-sm { padding: 8px 16px; font-size: 13px; }
        /* Detail Cards */
        .detail-grid {
            display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;
        }
        .detail-card {
            background: #fff; border-radius: 14px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04); padding: 28px;
        }
        .detail-card.full-width { grid-column: 1 / -1; }
        .detail-card h3 {
            font-size: 16px; font-weight: 700; color: #6B5335;
            margin-bottom: 20px; padding-bottom: 12px; border-bottom: 1px solid #f0ebe5;
        }
        .detail-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 10px 0; border-bottom: 1px solid #faf8f5;
        }
        .detail-row:last-child { border-bottom: none; }
        .detail-label { font-size: 14px; color: #999; font-weight: 600; }
        .detail-value { font-size: 14px; color: #333; font-weight: 700; }
        .badge {
            display: inline-block; padding: 4px 14px; border-radius: 20px;
            font-size: 12px; font-weight: 700;
        }
        .badge-pending { background: #fff3e0; color: #e65100; }
        .badge-paid { background: #e8f5e9; color: #2e7d32; }
        .badge-delivered { background: #e3f2fd; color: #1565c0; }
        .badge-cancelled { background: #ffebee; color: #c62828; }
        /* Receipt Image */
        .receipt-container { margin-top: 16px; }
        .receipt-img {
            max-width: 100%; max-height: 500px; border-radius: 10px;
            border: 2px solid #e8e0d8; cursor: pointer;
        }
        .receipt-img:hover { border-color: #8B6F47; }
        /* Status Update Form */
        .status-form {
            display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap;
        }
        .status-form .form-group { margin-bottom: 0; flex: 1; min-width: 200px; }
        .status-form label {
            display: block; font-size: 13px; font-weight: 700;
            color: #888; margin-bottom: 6px;
        }
        .status-form select {
            width: 100%; padding: 10px 16px;
            border: 2px solid #e8e0d8; border-radius: 10px;
            font-family: 'Cairo', sans-serif; font-size: 14px; color: #333;
            direction: rtl; cursor: pointer;
        }
        .status-form select:focus { outline: none; border-color: #8B6F47; }
        /* Actions Bar */
        .actions-bar {
            display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
            margin-top: 24px;
        }
        .mobile-toggle {
            display: none; position: fixed; top: 16px; right: 16px; z-index: 200;
            background: #6B5335; color: #fff; border: none; border-radius: 10px;
            width: 44px; height: 44px; font-size: 20px; cursor: pointer;
        }
        .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 90; }
        @media (max-width: 768px) {
            .mobile-toggle { display: block; }
            .sidebar { transform: translateX(100%); }
            .sidebar.open { transform: translateX(0); }
            .sidebar-overlay.open { display: block; }
            .main-content { margin-right: 0; padding: 24px 16px; padding-top: 72px; }
            .detail-grid { grid-template-columns: 1fr; }
            .status-form { flex-direction: column; }
        }
    </style>
</head>
<body>
    <button class="mobile-toggle" onclick="document.querySelector('.sidebar').classList.toggle('open'); document.querySelector('.sidebar-overlay').classList.toggle('open');">&#9776;</button>
    <div class="sidebar-overlay" onclick="document.querySelector('.sidebar').classList.remove('open'); this.classList.remove('open');"></div>

    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <h2>لوحة التحكم</h2>
                <p>ادارة المتجر</p>
            </div>
            <ul class="sidebar-nav">
                <li><a href="/admin">
                    <svg viewBox="0 0 24 24"><path d="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/></svg>
                    الرئيسية
                </a></li>
                <li><a href="/admin/products">
                    <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 14H4V6h16v12zM6 10h2v2H6zm0 4h8v2H6zm10 0h2v2h-2zm-6-4h8v2h-8z"/></svg>
                    المنتجات
                </a></li>
                <li><a href="/admin/orders" class="active">
                    <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10H7v-2h10v2z"/></svg>
                    الطلبات
                </a></li>
                <li><a href="/admin/reviews">
                    <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
                    التعليقات
                </a></li>
            </ul>
            <div class="sidebar-footer">
                <a href="/admin/logout">
                    <svg viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                    تسجيل الخروج
                </a>
            </div>
        </aside>

        <main class="main-content">
            <div class="page-header">
                <h1 class="page-title">تفاصيل الطلب #<%= order.order_ref %></h1>
                <a href="/admin/orders" class="btn btn-secondary">&#8592; رجوع للطلبات</a>
            </div>

            <div class="detail-grid">
                <!-- Order Info -->
                <div class="detail-card">
                    <h3>معلومات الطلب</h3>
                    <div class="detail-row">
                        <span class="detail-label">رقم الطلب</span>
                        <span class="detail-value"><%= order.order_ref %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">المنتج</span>
                        <span class="detail-value"><%= order.product_title %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">الكمية</span>
                        <span class="detail-value"><%= order.quantity || 1 %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">المبلغ</span>
                        <span class="detail-value"><%= order.payment_amount %> ر.س</span>
                    </div>
                    <% if (order.deposit_amount) { %>
                    <div class="detail-row">
                        <span class="detail-label">العربون</span>
                        <span class="detail-value"><%= order.deposit_amount %> ر.س</span>
                    </div>
                    <% } %>
                    <div class="detail-row">
                        <span class="detail-label">طريقة الدفع</span>
                        <span class="detail-value"><%= order.payment_method || '-' %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">الحالة</span>
                        <span class="detail-value">
                            <span class="badge badge-<%= order.status %>">
                                <%= order.status === 'pending' ? 'معلق' : order.status === 'paid' ? 'مدفوع' : order.status === 'delivered' ? 'تم التسليم' : 'ملغي' %>
                            </span>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">تاريخ الطلب</span>
                        <span class="detail-value"><%= new Date(order.created_at).toLocaleString('ar-SA') %></span>
                    </div>
                </div>

                <!-- Customer Info -->
                <div class="detail-card">
                    <h3>معلومات العميل</h3>
                    <div class="detail-row">
                        <span class="detail-label">الاسم</span>
                        <span class="detail-value"><%= order.full_name %></span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">الجوال</span>
                        <span class="detail-value" dir="ltr"><%= order.phone %></span>
                    </div>
                    <% if (order.email) { %>
                    <div class="detail-row">
                        <span class="detail-label">البريد</span>
                        <span class="detail-value" dir="ltr"><%= order.email %></span>
                    </div>
                    <% } %>
                    <% if (order.city) { %>
                    <div class="detail-row">
                        <span class="detail-label">المدينة</span>
                        <span class="detail-value"><%= order.city %></span>
                    </div>
                    <% } %>
                    <% if (order.address) { %>
                    <div class="detail-row">
                        <span class="detail-label">العنوان</span>
                        <span class="detail-value"><%= order.address %></span>
                    </div>
                    <% } %>
                    <% if (order.notes) { %>
                    <div class="detail-row">
                        <span class="detail-label">ملاحظات</span>
                        <span class="detail-value"><%= order.notes %></span>
                    </div>
                    <% } %>
                </div>

                <!-- Receipt Image -->
                <% if (order.receipt_filename) { %>
                <div class="detail-card full-width">
                    <h3>صورة ايصال الدفع</h3>
                    <div class="receipt-container">
                        <a href="/uploads/receipts/<%= order.receipt_filename %>" target="_blank">
                            <img src="/uploads/receipts/<%= order.receipt_filename %>" alt="ايصال الدفع" class="receipt-img">
                        </a>
                    </div>
                </div>
                <% } %>

                <!-- Status Update -->
                <div class="detail-card full-width">
                    <h3>تحديث الحالة</h3>
                    <form method="POST" action="/admin/orders/<%= order.id %>/status" class="status-form">
                        <div class="form-group">
                            <label>الحالة الجديدة</label>
                            <select name="status">
                                <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>معلق</option>
                                <option value="paid" <%= order.status === 'paid' ? 'selected' : '' %>>مدفوع</option>
                                <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>تم التسليم</option>
                                <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>ملغي</option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary">تحديث الحالة</button>
                    </form>
                </div>
            </div>

            <!-- Actions Bar -->
            <div class="actions-bar">
                <form method="POST" action="/admin/orders/<%= order.id %>/delete" style="display:inline;" onclick="return confirm('هل أنت متأكد من حذف هذا الطلب؟ لا يمكن التراجع عن هذا الاجراء.')">
                    <button type="submit" class="btn btn-delete">حذف الطلب</button>
                </form>
            </div>
        </main>
    </div>
</body>
</html>
