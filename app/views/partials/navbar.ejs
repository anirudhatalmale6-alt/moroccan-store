<nav class="navbar<%= typeof scrolled !== 'undefined' && scrolled ? ' scrolled' : '' %>">
  <div class="container">
    <div class="navbar__inner">
      <div class="navbar__brand">
        <a href="/" style="display: flex; align-items: center; gap: 10px;">
          <div class="navbar__logo">م</div>
          <span class="navbar__name">متجرنا</span>
        </a>
      </div>
      <div style="display: flex; align-items: center; gap: 12px;">
        <a href="/cart" style="position: relative; font-size: 20px; color: inherit; text-decoration: none; opacity: 0.8;" title="السلة">🛒</a>
        <% if (typeof product !== 'undefined' && product) { %>
          <a href="/product/<%= product.slug %>/checkout" class="navbar__cta">🛒 اطلب الآن</a>
        <% } else { %>
          <a href="/" class="navbar__cta">🏠 الرئيسية</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>
