<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <%- include('partials/head') %>
  <title><%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %> — منتجاتنا</title>
</head>
<body>
  <div class="pattern-overlay"></div>

  <!-- Navbar -->
  <nav class="navbar scrolled">
    <div class="container">
      <div class="navbar__inner">
        <div class="navbar__brand">
          <a href="/" style="display: flex; align-items: center; gap: 10px;">
            <div class="navbar__logo"><%= typeof siteName !== 'undefined' ? siteName.charAt(0) : 'م' %></div>
            <span class="navbar__name"><%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></span>
          </a>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
          <a href="/cart" style="position: relative; font-size: 22px; color: var(--color-text); text-decoration: none;">🛒<% if (typeof cartCount !== 'undefined' && cartCount > 0) { %><span id="cartBadge" style="position: absolute; top: -8px; right: -8px; background: var(--color-error); color: white; font-size: 11px; font-weight: 700; min-width: 18px; height: 18px; border-radius: 50%; display: flex; align-items: center; justify-content: center;"><%= cartCount %></span><% } %></a>
          <a href="/login" class="navbar__cta" style="font-size: 13px; padding: 8px 16px;">تسجيل الدخول</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Image Slider -->
  <% if (typeof sliders !== 'undefined' && sliders && sliders.length > 0) { %>
  <section class="home-slider" style="position: relative; overflow: hidden; margin-top: 0;">
    <div class="slider-container" id="sliderContainer" style="display: flex; transition: transform 0.5s ease; width: <%= sliders.length * 100 %>%;">
      <% sliders.forEach(function(slide) { %>
        <div class="slider-slide" style="flex: 0 0 <%= 100 / sliders.length %>%; position: relative;">
          <% if (slide.link_url) { %>
            <a href="<%= slide.link_url %>">
          <% } %>
            <img src="/uploads/sliders/<%= slide.image_filename %>" alt="<%= slide.title || '' %>" style="width: 100%; height: auto; max-height: 500px; object-fit: cover; display: block;">
            <% if (slide.title) { %>
              <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 30px; background: linear-gradient(transparent, rgba(0,0,0,0.6)); color: white;">
                <h3 style="font-size: 20px; font-weight: 700; margin: 0;"><%= slide.title %></h3>
              </div>
            <% } %>
          <% if (slide.link_url) { %>
            </a>
          <% } %>
        </div>
      <% }); %>
    </div>
    <% if (sliders.length > 1) { %>
    <button type="button" onclick="slideNext()" style="position: absolute; top: 50%; left: 12px; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; border-radius: 50%; width: 40px; height: 40px; font-size: 18px; cursor: pointer; box-shadow: var(--shadow-sm);">→</button>
    <button type="button" onclick="slidePrev()" style="position: absolute; top: 50%; right: 12px; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; border-radius: 50%; width: 40px; height: 40px; font-size: 18px; cursor: pointer; box-shadow: var(--shadow-sm);">←</button>
    <div style="position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px;">
      <% sliders.forEach(function(s, idx) { %>
        <div class="slider-dot<%= idx === 0 ? ' active' : '' %>" data-index="<%= idx %>" onclick="slideTo(<%= idx %>)" style="width: 10px; height: 10px; border-radius: 50%; background: <%= idx === 0 ? 'var(--color-primary)' : 'rgba(255,255,255,0.6)' %>; cursor: pointer; transition: var(--transition-fast);"></div>
      <% }); %>
    </div>
    <% } %>
  </section>
  <% } %>

  <!-- Categories Section -->
  <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
  <section style="padding: 20px 0 10px;">
    <div class="container">
      <div style="display: flex; overflow-x: auto; gap: 16px; padding: 4px 0; -webkit-overflow-scrolling: touch;">
        <% categories.forEach(function(cat) { %>
          <a href="/?category=<%= cat.slug %>" style="text-decoration: none; flex: 0 0 auto; text-align: center; width: 80px;">
            <div style="width: 64px; height: 64px; border-radius: 50%; overflow: hidden; margin: 0 auto 8px; border: 2px solid var(--color-border); background: var(--color-bg-warm);">
              <% if (cat.image_filename) { %>
                <img src="/uploads/categories/<%= cat.image_filename %>" alt="<%= cat.name %>" style="width: 100%; height: 100%; object-fit: cover;">
              <% } else { %>
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 28px;">&#x1F4E6;</div>
              <% } %>
            </div>
            <span style="font-size: 12px; font-weight: 600; color: var(--color-text); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= cat.name %></span>
          </a>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Products Section -->
  <section class="hero" style="padding-top: 30px; padding-bottom: 60px;">
    <div class="container">
      <div class="section-header" style="margin-top: 0;">
        <span class="section-header__label">تسوق الآن</span>
        <h1 class="section-header__title">منتجاتنا</h1>
        <div class="section-header__divider"></div>
      </div>

      <div class="products-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
        <% products.forEach(function(p) { %>
          <a href="/product/<%= p.slug %>" class="feature-card" style="text-decoration: none; cursor: pointer; padding: 0; overflow: hidden;">
            <!-- Product Image -->
            <div style="width: 100%; height: 200px; overflow: hidden; background: var(--color-bg-warm); border-radius: var(--radius-md) var(--radius-md) 0 0;">
              <% if (p.main_image) { %>
                <img src="/uploads/products/<%= p.main_image %>" alt="<%= p.title %>" style="width: 100%; height: 100%; object-fit: cover;">
              <% } else if (p.video_filename) { %>
                <video muted loop playsinline style="width: 100%; height: 100%; object-fit: cover;" onmouseenter="this.play()" onmouseleave="this.pause()">
                  <source src="/uploads/products/<%= p.video_filename %>" type="video/mp4">
                </video>
              <% } else { %>
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 64px;">🛍️</div>
              <% } %>
            </div>
            <!-- Product Info -->
            <div style="padding: 20px; text-align: center;">
              <h3 class="feature-card__title" style="margin-top: 0;"><%= p.title %></h3>
              <div style="display: flex; align-items: baseline; justify-content: center; gap: 8px; margin-top: 12px;">
                <span style="font-size: 24px; font-weight: 800; color: var(--color-primary);"><%= p.price %> درهم</span>
                <% if (p.old_price && p.old_price > p.price) { %>
                  <span style="font-size: 14px; color: var(--color-text-muted); text-decoration: line-through;"><%= p.old_price %> درهم</span>
                  <span style="padding: 2px 10px; background: var(--color-error-light); color: var(--color-error); border-radius: 50px; font-size: 11px; font-weight: 700;">
                    -<%= Math.round(((p.old_price - p.price) / p.old_price) * 100) %>%
                  </span>
                <% } %>
              </div>
              <div style="margin-top: 16px;">
                <span class="btn btn--primary" style="font-size: 14px; padding: 10px 28px;">عرض المنتج</span>
              </div>
            </div>
          </a>
        <% }); %>
      </div>

      <div id="loadingMore" style="text-align: center; padding: 20px; display: none;">
        <span style="color: var(--color-text-muted);">جاري تحميل المزيد...</span>
      </div>

      <% if (products.length === 0) { %>
        <div style="text-align: center; padding: 60px 20px; color: var(--color-text-muted);">
          <p style="font-size: 48px; margin-bottom: 16px;">🏪</p>
          <p style="font-size: 18px; font-weight: 600;">لا توجد منتجات متاحة حالياً</p>
        </div>
      <% } %>
    </div>
  </section>

  <%- include('partials/footer') %>

  <script>
    // Infinite scroll
    var currentPage = 1;
    var isLoadingMore = false;
    var hasMoreProducts = <%= products.length >= 6 ? 'true' : 'false' %>;

    window.addEventListener('scroll', function() {
      if (isLoadingMore || !hasMoreProducts) return;
      if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 300) {
        loadMoreProducts();
      }
    });

    function loadMoreProducts() {
      if (isLoadingMore || !hasMoreProducts) return;
      isLoadingMore = true;
      currentPage++;
      document.getElementById('loadingMore').style.display = 'block';

      fetch('/api/products?page=' + currentPage + '&limit=6')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.products && data.products.length > 0) {
          var grid = document.querySelector('.products-grid');
          data.products.forEach(function(p) {
            var card = document.createElement('a');
            card.href = '/product/' + p.slug;
            card.className = 'feature-card';
            card.style.cssText = 'text-decoration: none; cursor: pointer; padding: 0; overflow: hidden;';

            var imgHtml = '';
            if (p.main_image) {
              imgHtml = '<img src="/uploads/products/' + p.main_image + '" alt="' + p.title + '" style="width: 100%; height: 100%; object-fit: cover;">';
            } else {
              imgHtml = '<div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 64px;">&#x1f6cd;&#xfe0f;</div>';
            }

            var priceHtml = '<span style="font-size: 20px; font-weight: 800; color: var(--color-primary);">' + p.price + ' درهم</span>';
            if (p.old_price && p.old_price > p.price) {
              priceHtml += ' <span style="font-size: 13px; color: var(--color-text-muted); text-decoration: line-through;">' + p.old_price + ' درهم</span>';
              priceHtml += ' <span style="padding: 2px 8px; background: var(--color-error-light); color: var(--color-error); border-radius: 50px; font-size: 10px; font-weight: 700;">-' + Math.round(((p.old_price - p.price) / p.old_price) * 100) + '%</span>';
            }

            card.innerHTML = '<div style="width: 100%; height: 200px; overflow: hidden; background: var(--color-bg-warm); border-radius: var(--radius-md) var(--radius-md) 0 0;">' + imgHtml + '</div>' +
              '<div style="padding: 16px; text-align: center;">' +
              '<h3 class="feature-card__title" style="margin-top: 0; font-size: 15px;">' + p.title + '</h3>' +
              '<div style="display: flex; align-items: baseline; justify-content: center; gap: 6px; margin-top: 8px;">' + priceHtml + '</div>' +
              '<div style="margin-top: 12px;"><span class="btn btn--primary" style="font-size: 13px; padding: 8px 20px;">عرض المنتج</span></div>' +
              '</div>';

            grid.appendChild(card);
          });
          hasMoreProducts = data.hasMore;
        } else {
          hasMoreProducts = false;
        }
        isLoadingMore = false;
        document.getElementById('loadingMore').style.display = 'none';
      })
      .catch(function() {
        isLoadingMore = false;
        document.getElementById('loadingMore').style.display = 'none';
      });
    }

    // Slider logic
    var currentSlide = 0;
    var totalSlides = <%= typeof sliders !== 'undefined' && sliders ? sliders.length : 0 %>;

    function slideTo(index) {
      currentSlide = index;
      var container = document.getElementById('sliderContainer');
      if (container) {
        container.style.transform = 'translateX(' + (currentSlide * (100 / totalSlides)) + '%)';
      }
      // Update dots
      document.querySelectorAll('.slider-dot').forEach(function(dot, i) {
        dot.style.background = i === currentSlide ? 'var(--color-primary)' : 'rgba(255,255,255,0.6)';
        dot.classList.toggle('active', i === currentSlide);
      });
    }

    function slideNext() {
      slideTo((currentSlide + 1) % totalSlides);
    }

    function slidePrev() {
      slideTo((currentSlide - 1 + totalSlides) % totalSlides);
    }

    // Auto-slide
    if (totalSlides > 1) {
      setInterval(function() { slideNext(); }, 5000);
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
