<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
  <%- include('partials/head') %>
  <title><%= (typeof metaTitle !== 'undefined' && metaTitle) ? metaTitle : ((typeof siteName !== 'undefined' ? siteName : 'متجرنا') + ' — ' + t('our_products')) %></title>
</head>
<body>
  <div class="pattern-overlay"></div>

  <!-- Navbar -->
  <nav class="navbar scrolled">
    <div class="container">
      <div class="navbar__inner">
        <div class="navbar__brand">
          <a href="/" style="display: flex; align-items: center; gap: 10px;">
            <div class="navbar__logo"><%= typeof siteName !== 'undefined' ? siteName.charAt(0) : 'م' %></div>
            <span class="navbar__name"><%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></span>
          </a>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
          <a href="<%= (typeof cartMode !== 'undefined' && cartMode === 'drawer') ? 'javascript:void(0)' : '/cart' %>" id="cartLink" onclick="<%= (typeof cartMode !== 'undefined' && cartMode === 'drawer') ? 'openCartDrawer();return false;' : '' %>" style="position: relative; font-size: 22px; color: var(--color-text); text-decoration: none;">🛒<span id="cartBadge" style="position: absolute; top: -8px; right: -8px; background: var(--color-error); color: white; font-size: 11px; font-weight: 700; min-width: 18px; height: 18px; border-radius: 50%; display: <%= (typeof cartCount !== 'undefined' && cartCount > 0) ? 'flex' : 'none' %>; align-items: center; justify-content: center;"><%= (typeof cartCount !== 'undefined' && cartCount > 0) ? cartCount : '0' %></span></a>
          <% if (typeof sidebarCategories !== 'undefined' && sidebarCategories && sidebarCategories.length > 0) { %>
          <button type="button" onclick="openSidebar()" style="background: none; border: none; font-size: 22px; cursor: pointer; color: var(--color-text); padding: 4px; line-height: 1; opacity: 0.8;" title="<%= t('menu') %>">☰</button>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Image Slider -->
  <% if (typeof sliders !== 'undefined' && sliders && sliders.length > 0) { %>
  <section class="home-slider" style="position: relative; overflow: hidden; margin-top: 0;">
    <div class="slider-container" id="sliderContainer" style="display: flex; transition: transform 0.5s ease; width: <%= sliders.length * 100 %>%;">
      <% sliders.forEach(function(slide) { %>
        <div class="slider-slide" style="flex: 0 0 <%= 100 / sliders.length %>%; position: relative;">
          <% if (slide.link_url) { %>
            <a href="<%= slide.link_url %>">
          <% } %>
            <img src="/uploads/sliders/<%= slide.image_filename %>" alt="<%= slide.title || '' %>" style="width: 100%; height: auto; max-height: 500px; object-fit: cover; display: block;">
            <% if (slide.title) { %>
              <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 20px 30px; background: linear-gradient(transparent, rgba(0,0,0,0.6)); color: white;">
                <h3 style="font-size: 20px; font-weight: 700; margin: 0;"><%= slide.title %></h3>
              </div>
            <% } %>
          <% if (slide.link_url) { %>
            </a>
          <% } %>
        </div>
      <% }); %>
    </div>
    <% if (sliders.length > 1) { %>
    <button type="button" onclick="slideNext()" style="position: absolute; top: 50%; left: 12px; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; border-radius: 50%; width: 40px; height: 40px; font-size: 18px; cursor: pointer; box-shadow: var(--shadow-sm);">→</button>
    <button type="button" onclick="slidePrev()" style="position: absolute; top: 50%; right: 12px; transform: translateY(-50%); background: rgba(255,255,255,0.8); border: none; border-radius: 50%; width: 40px; height: 40px; font-size: 18px; cursor: pointer; box-shadow: var(--shadow-sm);">←</button>
    <div style="position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px;">
      <% sliders.forEach(function(s, idx) { %>
        <div class="slider-dot<%= idx === 0 ? ' active' : '' %>" data-index="<%= idx %>" onclick="slideTo(<%= idx %>)" style="width: 10px; height: 10px; border-radius: 50%; background: <%= idx === 0 ? 'var(--color-primary)' : 'rgba(255,255,255,0.6)' %>; cursor: pointer; transition: var(--transition-fast);"></div>
      <% }); %>
    </div>
    <% } %>
  </section>
  <% } %>

  <!-- Categories Section -->
  <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
  <section style="padding: 20px 0 10px;">
    <div class="container">
      <div style="display: flex; overflow-x: auto; gap: 16px; padding: 4px 0; -webkit-overflow-scrolling: touch;">
        <% categories.forEach(function(cat) { %>
          <a href="/category/<%= cat.slug %>" style="text-decoration: none; flex: 0 0 auto; text-align: center; width: 80px;">
            <div style="width: 64px; height: 64px; border-radius: 50%; overflow: hidden; margin: 0 auto 8px; border: 2px solid var(--color-border); background: var(--color-bg-warm);">
              <% if (cat.image_filename) { %>
                <img src="/uploads/categories/<%= cat.image_filename %>" alt="<%= cat.name %>" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy">
              <% } else { %>
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 28px;">&#x1F4E6;</div>
              <% } %>
            </div>
            <span style="font-size: 12px; font-weight: 600; color: var(--color-text); display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= cat.name %></span>
          </a>
        <% }); %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Products Section -->
  <section class="hero" style="padding-top: 30px; padding-bottom: 60px;">
    <div class="container">
      <div class="section-header" style="margin-top: 0;">
        <span class="section-header__label"><%= t('shop_now') %></span>
        <h1 class="section-header__title"><%= typeof currentCategory !== 'undefined' && currentCategory ? currentCategory.name : t('our_products') %></h1>
        <div class="section-header__divider"></div>
      </div>

      <% var _banners = (typeof banners !== 'undefined' && banners) ? banners : []; %>
      <% var _bInterval = (typeof bannerInterval !== 'undefined') ? bannerInterval : 4; %>
      <% var _bIdx = 0; %>
      <div class="products-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">
        <% products.forEach(function(p, idx) { %>
          <%/* Insert banner after every N products */%>
          <% if (_banners.length > 0 && idx > 0 && idx % _bInterval === 0) { %>
            <% var _b = _banners[_bIdx % _banners.length]; _bIdx++; %>
            <div class="grid-banner" style="grid-column: 1 / -1; border-radius: 12px; overflow: hidden;">
              <% if (_b.link_url) { %><a href="<%= _b.link_url %>" style="display:block;"><% } %>
                <picture>
                  <% if (_b.mobile_image) { %><source media="(max-width: 600px)" srcset="/uploads/banners/<%= _b.mobile_image %>"><% } %>
                  <img src="/uploads/banners/<%= _b.desktop_image %>" alt="" style="width: 100%; height: auto; display: block; border-radius: 12px;" loading="lazy">
                </picture>
              <% if (_b.link_url) { %></a><% } %>
            </div>
          <% } %>
          <a href="/product/<%= p.slug %>" class="product-card" style="text-decoration: none; cursor: pointer; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); transition: transform 0.2s, box-shadow 0.2s; display: block;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)';" onmouseout="this.style.transform=''; this.style.boxShadow='0 1px 4px rgba(0,0,0,0.06)';">
            <div style="width: 100%; aspect-ratio: 1; overflow: hidden; background: #f8f6f3; position: relative;">
              <% if (p.main_image) { %>
                <img src="/uploads/products/<%= p.main_image %>" alt="<%= p.title %>" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy">
              <% } else if (p.video_filename) { %>
                <video muted loop playsinline preload="none" style="width: 100%; height: 100%; object-fit: cover;" onmouseenter="this.play()" onmouseleave="this.pause()">
                  <source src="/uploads/products/<%= p.video_filename %>" type="video/mp4">
                </video>
              <% } else { %>
                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48px; color: #ccc;">🛍️</div>
              <% } %>
              <% if (p.old_price && p.old_price > p.price) { %>
                <span style="position: absolute; top: 8px; left: 8px; background: #e74c3c; color: #fff; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 6px;">-<%= Math.round(((p.old_price - p.price) / p.old_price) * 100) %>%</span>
              <% } %>
            </div>
            <div style="padding: 10px 12px 14px;">
              <h3 style="font-size: 13px; font-weight: 600; color: #333; margin: 0 0 6px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= p.title %></h3>
              <div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">
                <span style="font-size: 16px; font-weight: 800; color: var(--color-primary);"><%= p.price %> <span style="font-size: 12px; font-weight: 600;"><%= t('currency') %></span></span>
                <% if (p.old_price && p.old_price > p.price) { %>
                  <span style="font-size: 12px; color: #aaa; text-decoration: line-through;"><%= p.old_price %></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }); %>
      </div>

      <div id="loadingMore" style="text-align: center; padding: 20px; display: none;">
        <span style="color: var(--color-text-muted);"><%= t('loading_more') %></span>
      </div>

      <% if (products.length === 0) { %>
        <div style="text-align: center; padding: 60px 20px; color: var(--color-text-muted);">
          <p style="font-size: 48px; margin-bottom: 16px;">🏪</p>
          <p style="font-size: 18px; font-weight: 600;"><%= t('no_products') %></p>
        </div>
      <% } %>
    </div>
  </section>

  <!-- Customer Feedback Section -->
  <% if (typeof latestReviews !== 'undefined' && latestReviews && latestReviews.length > 0) { %>
  <section style="padding: 40px 0 50px; background: linear-gradient(135deg, #faf8f5 0%, #f0ebe5 100%);">
    <div class="container">
      <div class="section-header" style="margin-top: 0;">
        <span class="section-header__label"><%= t('what_customers_say') %></span>
        <h2 class="section-header__title"><%= t('customer_feedback') %></h2>
        <div class="section-header__divider"></div>
      </div>

      <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 24px;">
        <% latestReviews.forEach(function(rev) { %>
          <div style="background: #fff; border-radius: 12px; padding: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); overflow: hidden;">
            <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
              <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--color-primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0;"><%= (function(n){ var e=['😊','😎','🤩','😇','🥰','😄','🤗','😺','🦊','🐻','🐶','🐱','🐸','🦁','🐼','🐯','🐨','🦋','🌸','⭐']; if(!n) return e[0]; var h=0; for(var i=0;i<n.length;i++) h=((h<<5)-h)+n.charCodeAt(i); return e[Math.abs(h)%e.length]; })(rev.name || 'عميل') %></div>
              <div style="flex: 1; min-width: 0;">
                <div style="font-size: 12px; font-weight: 700; color: #333; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"><%= rev.name || 'عميل' %></div>
                <div style="color: #f0a500; font-size: 11px; letter-spacing: 1px;">
                  <% for (var i = 1; i <= 5; i++) { %><%= i <= rev.rating ? '★' : '☆' %><% } %>
                </div>
              </div>
            </div>
            <% if (rev.image_filename) { %>
              <div style="margin-bottom: 8px; border-radius: 8px; overflow: hidden;">
                <img src="/uploads/reviews/<%= rev.image_filename %>" alt="" style="width: 100%; height: 120px; object-fit: cover; display: block;" loading="lazy">
              </div>
            <% } %>
            <% if (rev.message) { %>
              <p style="font-size: 12px; color: #666; line-height: 1.6; margin: 0 0 6px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;"><%= rev.message %></p>
            <% } %>
            <% if (rev.audio_filename) { %>
              <div class="wa-audio-player" data-src="/uploads/reviews/<%= rev.audio_filename %>" style="margin-top: 4px;">
                <button type="button" class="wa-play-btn" onclick="toggleWaAudio(this)" style="width: 30px; height: 30px; font-size: 12px;">▶</button>
                <div class="wa-progress-wrap" onclick="seekWaAudio(event, this)">
                  <div class="wa-waveform"></div>
                </div>
                <span class="wa-time" style="font-size: 11px;">0:00</span>
              </div>
            <% } %>
          </div>
        <% }); %>
      </div>

      <div style="text-align: center;">
        <a href="/feedback" style="display: inline-flex; align-items: center; gap: 8px; padding: 12px 32px; background: var(--color-primary); color: #fff; text-decoration: none; border-radius: 10px; font-size: 15px; font-weight: 700; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          <%= t('view_all_reviews') %> (<%= typeof homeReviewCount !== 'undefined' ? homeReviewCount : '' %>)
        </a>
      </div>
    </div>
  </section>
  <% } %>

  <%- include('partials/footer') %>

  <script>
    // Infinite scroll with banner support
    var currentPage = 1;
    var isLoadingMore = false;
    var hasMoreProducts = <%= products.length >= 6 ? 'true' : 'false' %>;
    var totalProductCount = <%= products.length %>;
    var bannerIdx = <%= typeof _bIdx !== 'undefined' ? _bIdx : 0 %>;

    window.addEventListener('scroll', function() {
      if (isLoadingMore || !hasMoreProducts) return;
      if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 300) {
        loadMoreProducts();
      }
    });

    function createBannerHtml(banner) {
      var html = '<div class="grid-banner" style="grid-column: 1 / -1; border-radius: 12px; overflow: hidden;">';
      if (banner.link_url) html += '<a href="' + banner.link_url + '" style="display:block;">';
      html += '<picture>';
      if (banner.mobile_image) html += '<source media="(max-width: 600px)" srcset="/uploads/banners/' + banner.mobile_image + '">';
      html += '<img src="/uploads/banners/' + banner.desktop_image + '" alt="" style="width: 100%; height: auto; display: block; border-radius: 12px;" loading="lazy">';
      html += '</picture>';
      if (banner.link_url) html += '</a>';
      html += '</div>';
      return html;
    }

    function loadMoreProducts() {
      if (isLoadingMore || !hasMoreProducts) return;
      isLoadingMore = true;
      currentPage++;
      document.getElementById('loadingMore').style.display = 'block';

      fetch('/api/products?page=' + currentPage + '&limit=6')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.products && data.products.length > 0) {
          var grid = document.querySelector('.products-grid');
          var apiBanners = data.banners || [];
          var apiInterval = data.bannerInterval || 4;

          data.products.forEach(function(p) {
            // Check if we need to insert a banner before this product
            if (apiBanners.length > 0 && totalProductCount > 0 && totalProductCount % apiInterval === 0) {
              var b = apiBanners[bannerIdx % apiBanners.length];
              bannerIdx++;
              var bannerDiv = document.createElement('div');
              bannerDiv.innerHTML = createBannerHtml(b);
              grid.appendChild(bannerDiv.firstChild);
            }
            totalProductCount++;

            var card = document.createElement('a');
            card.href = '/product/' + p.slug;
            card.className = 'product-card';
            card.style.cssText = 'text-decoration: none; cursor: pointer; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); transition: transform 0.2s, box-shadow 0.2s; display: block;';

            var imgHtml = '';
            if (p.main_image) {
              imgHtml = '<img src="/uploads/products/' + p.main_image + '" alt="' + p.title + '" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy">';
            } else {
              imgHtml = '<div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 48px; color: #ccc;">&#x1f6cd;&#xfe0f;</div>';
            }

            var discountBadge = '';
            if (p.old_price && p.old_price > p.price) {
              discountBadge = '<span style="position: absolute; top: 8px; left: 8px; background: #e74c3c; color: #fff; font-size: 11px; font-weight: 700; padding: 3px 8px; border-radius: 6px;">-' + Math.round(((p.old_price - p.price) / p.old_price) * 100) + '%</span>';
            }

            var oldPriceHtml = '';
            if (p.old_price && p.old_price > p.price) {
              oldPriceHtml = '<span style="font-size: 12px; color: #aaa; text-decoration: line-through;">' + p.old_price + '</span>';
            }

            card.innerHTML = '<div style="width: 100%; aspect-ratio: 1; overflow: hidden; background: #f8f6f3; position: relative;">' + imgHtml + discountBadge + '</div>' +
              '<div style="padding: 10px 12px 14px;">' +
              '<h3 style="font-size: 13px; font-weight: 600; color: #333; margin: 0 0 6px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">' + p.title + '</h3>' +
              '<div style="display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;">' +
              '<span style="font-size: 16px; font-weight: 800; color: var(--color-primary);">' + p.price + ' <span style="font-size: 12px; font-weight: 600;"><%= t("currency") %></span></span>' +
              oldPriceHtml +
              '</div></div>';

            grid.appendChild(card);
          });
          hasMoreProducts = data.hasMore;
        } else {
          hasMoreProducts = false;
        }
        isLoadingMore = false;
        document.getElementById('loadingMore').style.display = 'none';
      })
      .catch(function() {
        isLoadingMore = false;
        document.getElementById('loadingMore').style.display = 'none';
      });
    }

    // Slider logic
    var currentSlide = 0;
    var totalSlides = <%= typeof sliders !== 'undefined' && sliders ? sliders.length : 0 %>;

    function slideTo(index) {
      currentSlide = index;
      var container = document.getElementById('sliderContainer');
      if (container) {
        container.style.transform = 'translateX(' + (currentSlide * (100 / totalSlides)) + '%)';
      }
      // Update dots
      document.querySelectorAll('.slider-dot').forEach(function(dot, i) {
        dot.style.background = i === currentSlide ? 'var(--color-primary)' : 'rgba(255,255,255,0.6)';
        dot.classList.toggle('active', i === currentSlide);
      });
    }

    function slideNext() {
      slideTo((currentSlide + 1) % totalSlides);
    }

    function slidePrev() {
      slideTo((currentSlide - 1 + totalSlides) % totalSlides);
    }

    // Auto-slide
    if (totalSlides > 1) {
      setInterval(function() { slideNext(); }, 5000);
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
