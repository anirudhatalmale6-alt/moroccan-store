<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
  <%- include('partials/head') %>
  <title><%= t('customer_feedback') %> — <%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></title>
  <style>
    /* ---- Rating Summary ---- */
    .rating-summary {
      background: var(--color-card);
      border-radius: var(--radius-lg);
      padding: 20px 24px;
      margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--color-border-light);
      display: flex;
      align-items: center;
      gap: 28px;
    }
    .rating-summary__left {
      text-align: center;
      min-width: 90px;
    }
    .rating-summary__big {
      font-size: 42px;
      font-weight: 800;
      color: var(--color-text);
      line-height: 1;
    }
    .rating-summary__stars {
      color: var(--color-star, #F5A623);
      font-size: 18px;
      letter-spacing: 2px;
      margin: 6px 0 4px;
    }
    .rating-summary__total {
      font-size: 12px;
      color: var(--color-text-muted);
    }
    .rating-summary__bars {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }
    .rating-bar-row {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
    }
    .rating-bar-row__label {
      color: var(--color-text-muted);
      min-width: 16px;
      text-align: center;
      font-weight: 600;
    }
    .rating-bar-row__star {
      color: var(--color-star, #F5A623);
      font-size: 12px;
    }
    .rating-bar-row__track {
      flex: 1;
      height: 8px;
      background: var(--color-border-light, #eee);
      border-radius: 4px;
      overflow: hidden;
    }
    .rating-bar-row__fill {
      height: 100%;
      background: var(--color-star, #F5A623);
      border-radius: 4px;
      transition: width 0.5s ease;
    }
    .rating-bar-row__count {
      color: var(--color-text-muted);
      font-size: 12px;
      min-width: 24px;
      text-align: end;
    }

    /* ---- Compact Hero ---- */
    .fb-hero {
      padding: 80px 0 16px;
      text-align: center;
    }
    .fb-hero h1 {
      font-family: var(--font-display);
      font-size: clamp(22px, 3.5vw, 32px);
      font-weight: 700;
      color: var(--color-text);
      margin: 0;
    }

    /* ---- Reviews Grid ---- */
    .fb-grid {
      padding: 8px 0 60px;
    }
    .fb-grid__inner {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    /* ---- Vertical Feedback Card (matches reference) ---- */
    .fbc {
      background: var(--color-card);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      border: 1px solid var(--color-border-light);
      display: flex;
      flex-direction: column;
    }

    /* Image area at top */
    .fbc__img-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 3/4;
      overflow: hidden;
      background: var(--color-bg-warm, #f8f5f0);
    }
    .fbc__img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .fbc__img-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 48px;
      background: linear-gradient(135deg, var(--color-bg-warm, #f8f5f0), var(--color-border-light, #eee));
    }

    /* Slider arrows on image */
    .fbc__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 26px;
      height: 26px;
      background: rgba(0,0,0,0.45);
      color: #fff;
      border: none;
      border-radius: 50%;
      cursor: pointer;
      font-size: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      padding: 0;
      line-height: 1;
      transition: background 0.2s;
    }
    .fbc__arrow:hover { background: rgba(0,0,0,0.7); }
    .fbc__arrow--prev { left: 6px; }
    .fbc__arrow--next { right: 6px; }
    [dir="rtl"] .fbc__arrow--prev { left: auto; right: 6px; }
    [dir="rtl"] .fbc__arrow--next { right: auto; left: 6px; }

    .fbc__dots {
      position: absolute;
      bottom: 8px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 4px;
    }
    .fbc__dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(255,255,255,0.5);
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.2s;
    }
    .fbc__dot.active {
      background: #fff;
    }

    .fbc__slider-track {
      display: flex;
      transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      height: 100%;
    }
    .fbc__slider-slide {
      flex: 0 0 100%;
      min-width: 0;
      height: 100%;
    }
    .fbc__slider-slide img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    /* Info section below image */
    .fbc__info {
      padding: 12px 14px 16px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      flex: 1;
    }
    .fbc__name {
      font-size: 15px;
      font-weight: 700;
      color: var(--color-text);
      margin: 0;
    }
    .fbc__stars {
      color: var(--color-star, #F5A623);
      font-size: 16px;
      letter-spacing: 2px;
    }
    .fbc__product {
      font-size: 11px;
      color: var(--color-text-muted);
    }

    /* Text/Audio content area (fixed min-height) */
    .fbc__content {
      padding: 0 14px 14px;
      min-height: 40px;
    }
    .fbc__text {
      font-size: 12px;
      line-height: 1.6;
      color: var(--color-text-secondary);
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .fbc__audio {
      margin-top: 4px;
    }
    .fbc__audio .wa-audio-player {
      transform: scale(0.85);
      transform-origin: center;
    }

    /* ---- Responsive ---- */
    @media (max-width: 600px) {
      .rating-summary {
        flex-direction: column;
        gap: 16px;
        padding: 16px;
      }
      .rating-summary__left {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .rating-summary__stars { margin: 0; }
      .fb-hero { padding: 72px 0 12px; }
      .fb-grid__inner { gap: 10px; }
      .fbc { border-radius: 12px; }
      .fbc__info { padding: 10px 10px 12px; }
      .fbc__name { font-size: 13px; }
      .fbc__stars { font-size: 14px; }
      .fbc__content { padding: 0 10px 10px; min-height: 32px; }
      .fbc__text { font-size: 11px; }
    }
    @media (min-width: 768px) {
      .fb-grid__inner {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    @media (min-width: 1024px) {
      .fb-grid__inner {
        grid-template-columns: repeat(4, 1fr);
      }
    }
  </style>
</head>
<body>
  <div class="pattern-overlay"></div>

  <!-- Navbar -->
  <nav class="navbar scrolled">
    <div class="container">
      <div class="navbar__inner">
        <div class="navbar__brand">
          <a href="/" style="display: flex; align-items: center; gap: 10px;">
            <% if (typeof desktopLogo !== 'undefined' && desktopLogo) { %>
              <img src="/uploads/settings/<%= desktopLogo %>" alt="" style="height: 36px; width: auto;">
            <% } else { %>
              <div class="navbar__logo"><%= typeof siteName !== 'undefined' ? siteName.charAt(0) : 'م' %></div>
              <span class="navbar__name"><%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></span>
            <% } %>
          </a>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
          <a href="/" style="font-size: 14px; font-weight: 700; color: var(--color-primary); text-decoration: none;">🏠 <%= t('home') %></a>
          <% if (typeof sidebarCategories !== 'undefined' && sidebarCategories && sidebarCategories.length > 0) { %>
          <button type="button" onclick="openSidebar()" style="background: none; border: none; font-size: 22px; cursor: pointer; color: var(--color-primary); padding: 4px; line-height: 1; opacity: 0.8;" title="<%= t('menu') %>">☰</button>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Compact Hero -->
  <section class="fb-hero">
    <div class="container">
      <h1><%= t('customer_reviews') %></h1>
    </div>
  </section>

  <!-- Rating Summary -->
  <section style="padding: 0 0 8px;">
    <div class="container">
      <div class="rating-summary">
        <div class="rating-summary__left">
          <div class="rating-summary__big"><%= avgRating %></div>
          <div>
            <div class="rating-summary__stars">
              <% for (var i = 1; i <= 5; i++) { %>
                <% if (i <= Math.round(parseFloat(avgRating))) { %>★<% } else { %>☆<% } %>
              <% } %>
            </div>
            <div class="rating-summary__total"><%= reviewCount %> <%= t('reviews_count') %></div>
          </div>
        </div>
        <div class="rating-summary__bars">
          <% for (var star = 5; star >= 1; star--) { %>
            <% var cnt = (typeof ratingDist !== 'undefined' && ratingDist[star]) ? ratingDist[star] : 0; %>
            <% var pct = reviewCount > 0 ? Math.round((cnt / reviewCount) * 100) : 0; %>
            <div class="rating-bar-row">
              <span class="rating-bar-row__label"><%= star %></span>
              <span class="rating-bar-row__star">★</span>
              <div class="rating-bar-row__track">
                <div class="rating-bar-row__fill" style="width: <%= pct %>%"></div>
              </div>
              <span class="rating-bar-row__count"><%= cnt %></span>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews Grid -->
  <section class="fb-grid">
    <div class="container">
      <% if (reviews.length === 0) { %>
        <div style="text-align: center; padding: 30px 16px; color: var(--color-text-muted);">
          <p style="font-size: 40px; margin-bottom: 12px;">💬</p>
          <p style="font-size: 16px; font-weight: 600; margin-bottom: 6px;"><%= t('no_reviews_yet') %></p>
          <p style="font-size: 13px;"><%= t('be_first_reviewer') %></p>
        </div>
      <% } else { %>
        <div class="fb-grid__inner">
          <% reviews.forEach(function(review, revIdx) { %>
            <%
              var _fimgs = [];
              if (review.image_filename) {
                try { _fimgs = JSON.parse(review.image_filename); } catch(e) { _fimgs = [review.image_filename]; }
                _fimgs = _fimgs.filter(function(img) { return !!img; });
              }
            %>
            <div class="fbc animate-on-scroll">
              <!-- Image at top -->
              <div class="fbc__img-wrap">
                <% if (_fimgs.length === 0) { %>
                  <div class="fbc__img-placeholder">
                    <%= (function(n){ var e=['😊','😎','🤩','😇','🥰','😄','🤗','😺','🦊','🐻','🐶','🐱','🐸','🦁','🐼','🐯','🐨','🦋','🌸','⭐']; if(!n) return e[0]; var h=0; for(var i=0;i<n.length;i++) h=((h<<5)-h)+n.charCodeAt(i); return e[Math.abs(h)%e.length]; })(review.name || '') %>
                  </div>
                <% } else if (_fimgs.length === 1) { %>
                  <img src="/uploads/reviews/<%= _fimgs[0] %>" alt="" loading="lazy">
                <% } else { %>
                  <div class="fbc__slider-track" id="fbTrack<%= revIdx %>" data-index="0" data-total="<%= _fimgs.length %>">
                    <% _fimgs.forEach(function(img) { %>
                      <div class="fbc__slider-slide">
                        <img src="/uploads/reviews/<%= img %>" alt="" loading="lazy">
                      </div>
                    <% }); %>
                  </div>
                  <button type="button" class="fbc__arrow fbc__arrow--prev" onclick="fbcSlide(<%= revIdx %>, -1)">‹</button>
                  <button type="button" class="fbc__arrow fbc__arrow--next" onclick="fbcSlide(<%= revIdx %>, 1)">›</button>
                  <div class="fbc__dots">
                    <% _fimgs.forEach(function(img, idx) { %>
                      <button type="button" class="fbc__dot<%= idx === 0 ? ' active' : '' %>" onclick="fbcSlideTo(<%= revIdx %>, <%= idx %>)"></button>
                    <% }); %>
                  </div>
                <% } %>
              </div>

              <!-- Name + Stars -->
              <div class="fbc__info">
                <p class="fbc__name"><%= review.name || t('customer') %></p>
                <div class="fbc__stars">
                  <% for (var j = 1; j <= 5; j++) { %>
                    <% if (j <= review.rating) { %>★<% } else { %>☆<% } %>
                  <% } %>
                </div>
                <% if (review.product_title) { %>
                  <div class="fbc__product"><%= review.product_title %></div>
                <% } %>
              </div>

              <!-- Text / Audio content -->
              <div class="fbc__content">
                <% if (review.message) { %>
                  <p class="fbc__text"><%= review.message %></p>
                <% } %>
                <% if (review.audio_filename) { %>
                  <div class="fbc__audio">
                    <div class="wa-audio-player" data-src="/uploads/reviews/<%= review.audio_filename %>">
                      <button type="button" class="wa-play-btn" onclick="toggleWaAudio(this)" style="width: 28px; height: 28px; font-size: 11px;">▶</button>
                      <div class="wa-progress-wrap" onclick="seekWaAudio(event, this)">
                        <div class="wa-waveform"></div>
                      </div>
                      <span class="wa-time" style="font-size: 11px;">0:00</span>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
  <script>
    function fbcSlide(id, dir) {
      var track = document.getElementById('fbTrack' + id);
      if (!track) return;
      var total = parseInt(track.dataset.total);
      var idx = parseInt(track.dataset.index || '0');
      var isRTL = document.documentElement.dir === 'rtl';
      idx += dir;
      if (idx < 0) idx = total - 1;
      if (idx >= total) idx = 0;
      track.dataset.index = idx;
      var offset = idx * 100;
      track.style.transform = isRTL ? 'translateX(' + offset + '%)' : 'translateX(-' + offset + '%)';
      // Update dots
      var wrap = track.parentElement;
      var dots = wrap.querySelectorAll('.fbc__dot');
      dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
    }
    function fbcSlideTo(id, target) {
      var track = document.getElementById('fbTrack' + id);
      if (!track) return;
      var isRTL = document.documentElement.dir === 'rtl';
      track.dataset.index = target;
      var offset = target * 100;
      track.style.transform = isRTL ? 'translateX(' + offset + '%)' : 'translateX(-' + offset + '%)';
      var wrap = track.parentElement;
      var dots = wrap.querySelectorAll('.fbc__dot');
      dots.forEach(function(d, i) { d.classList.toggle('active', i === target); });
    }
  </script>
</body>
</html>
