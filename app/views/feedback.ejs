<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'ar' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
<head>
  <%- include('partials/head') %>
  <title><%= t('customer_feedback') %> — <%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></title>
</head>
<body>
  <div class="pattern-overlay"></div>

  <!-- Navbar -->
  <nav class="navbar scrolled">
    <div class="container">
      <div class="navbar__inner">
        <div class="navbar__brand">
          <a href="/" style="display: flex; align-items: center; gap: 10px;">
            <% if (typeof desktopLogo !== 'undefined' && desktopLogo) { %>
              <img src="/uploads/settings/<%= desktopLogo %>" alt="" style="height: 36px; width: auto;">
            <% } else { %>
              <div class="navbar__logo"><%= typeof siteName !== 'undefined' ? siteName.charAt(0) : 'م' %></div>
              <span class="navbar__name"><%= typeof siteName !== 'undefined' ? siteName : 'متجرنا' %></span>
            <% } %>
          </a>
        </div>
        <div style="display: flex; align-items: center; gap: 12px;">
          <a href="/" style="font-size: 14px; font-weight: 700; color: var(--color-primary); text-decoration: none;">🏠 <%= t('home') %></a>
          <% if (typeof sidebarCategories !== 'undefined' && sidebarCategories && sidebarCategories.length > 0) { %>
          <button type="button" onclick="openSidebar()" style="background: none; border: none; font-size: 22px; cursor: pointer; color: var(--color-primary); padding: 4px; line-height: 1; opacity: 0.8;" title="<%= t('menu') %>">☰</button>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <!-- Reviews Hero -->
  <section class="reviews-hero">
    <div class="container">
      <div class="reviews-hero__inner">
        <h1 class="reviews-hero__title"><%= t('customer_reviews') %></h1>
        <div class="reviews-hero__rating">
          <span class="reviews-hero__stars">
            <% for (var i = 1; i <= 5; i++) { %>
              <% if (i <= Math.round(parseFloat(avgRating))) { %>★<% } else { %>☆<% } %>
            <% } %>
          </span>
          <span class="reviews-hero__score"><%= avgRating %></span>
          <span class="reviews-hero__count"><%= reviewCount %> <%= t('reviews_count') %></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews List -->
  <section class="reviews-list">
    <div class="container container--narrow">
      <% if (reviews.length === 0) { %>
        <div style="text-align: center; padding: 40px 20px; color: var(--color-text-muted);">
          <p style="font-size: 48px; margin-bottom: 16px;">💬</p>
          <p style="font-size: 18px; font-weight: 600; margin-bottom: 8px;"><%= t('no_reviews_yet') %></p>
          <p style="font-size: 14px;"><%= t('be_first_reviewer') %></p>
        </div>
      <% } else { %>
        <% reviews.forEach(function(review) { %>
          <div class="review-card animate-on-scroll">
            <div class="review-card__header">
              <% if (review.name) { %>
                <div class="review-card__avatar" style="font-size: 24px; display: flex; align-items: center; justify-content: center;"><%= (function(n){ var e=['😊','😎','🤩','😇','🥰','😄','🤗','😺','🦊','🐻','🐶','🐱','🐸','🦁','🐼','🐯','🐨','🦋','🌸','⭐']; if(!n) return e[0]; var h=0; for(var i=0;i<n.length;i++) h=((h<<5)-h)+n.charCodeAt(i); return e[Math.abs(h)%e.length]; })(review.name) %></div>
              <% } else { %>
                <div class="review-card__avatar" style="font-size: 24px; display: flex; align-items: center; justify-content: center;">⭐</div>
              <% } %>
              <div>
                <% if (review.name) { %>
                  <div class="review-card__name" style="display: flex; align-items: center; gap: 6px; flex-wrap: wrap;"><%= review.name %> <span style="background: var(--color-success, #2D8F5E); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 4px; white-space: nowrap;">✓ <%= t('verified') %></span></div>
                <% } else { %>
                  <div class="review-card__name" style="display: flex; align-items: center; gap: 6px;"><%= t('customer') %> <span style="background: var(--color-success, #2D8F5E); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 6px; border-radius: 4px; white-space: nowrap;">✓ <%= t('verified') %></span></div>
                <% } %>
                <div class="review-card__stars">
                  <% for (var j = 1; j <= 5; j++) { %>
                    <% if (j <= review.rating) { %>★<% } else { %>☆<% } %>
                  <% } %>
                </div>
                <% if (review.product_title) { %>
                  <div style="font-size: 12px; color: var(--color-text-muted); margin-top: 2px;"><%= t('on_product') %>: <%= review.product_title %></div>
                <% } %>
              </div>
            </div>

            <% if (review.message) { %>
              <div class="review-card__text"><%= review.message %></div>
            <% } %>

            <% if (review.image_filename) { %>
              <% var _fimgs = []; try { _fimgs = JSON.parse(review.image_filename); } catch(e) { _fimgs = [review.image_filename]; } %>
              <% if (_fimgs.length === 1 && _fimgs[0]) { %>
                <div style="margin-top: 16px; text-align: center;">
                  <img src="/uploads/reviews/<%= _fimgs[0] %>" alt="صورة التقييم" style="max-width: 100%; max-height: 300px; border-radius: var(--radius-md); object-fit: cover; border: 1px solid var(--color-border-light);" loading="lazy">
                </div>
              <% } else if (_fimgs.length > 1) { %>
                <div class="review-img-slider" style="margin-top: 16px; position: relative; overflow: hidden; border-radius: var(--radius-md);">
                  <div class="review-img-track" style="display: flex; transition: transform 0.3s ease; touch-action: pan-y;">
                    <% _fimgs.forEach(function(img) { if(img) { %>
                      <div style="flex: 0 0 100%; min-width: 0;">
                        <img src="/uploads/reviews/<%= img %>" alt="صورة التقييم" style="width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;" loading="lazy">
                      </div>
                    <% } }); %>
                  </div>
                  <div style="display: flex; justify-content: center; gap: 6px; padding: 8px 0 4px;">
                    <% _fimgs.forEach(function(img, idx) { if(img) { %>
                      <span class="review-slider-dot" style="width: 8px; height: 8px; border-radius: 50%; background: <%= idx === 0 ? 'var(--color-primary)' : 'var(--color-border)' %>; cursor: pointer; transition: background 0.2s;"></span>
                    <% } }); %>
                  </div>
                </div>
              <% } %>
            <% } %>

            <% if (review.audio_filename) { %>
              <div class="wa-audio-player" data-src="/uploads/reviews/<%= review.audio_filename %>" style="margin-top: 16px;">
                <button type="button" class="wa-play-btn" onclick="toggleWaAudio(this)">▶</button>
                <div class="wa-progress-wrap" onclick="seekWaAudio(event, this)">
                  <div class="wa-waveform"></div>
                </div>
                <span class="wa-time">0:00</span>
              </div>
            <% } %>
          </div>
        <% }); %>
      <% } %>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
